@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.TwoLetterISOLanguageName"
      dir="@(CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-success" dir="ltr" asp-controller="Home" asp-action="Home">
                <i class="bi bi-cart4 me-2"></i>ECommerce
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <ul class="navbar-nav mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Home" asp-action="Dashboard">
                                <i class="bi bi-speedometer2 me-1 text-success"></i> @Localizer["Dashboard"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Categories" asp-action="Index">
                                <i class="bi bi-tags me-1 text-success"></i> @Localizer["Categories"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-box-seam me-1 text-success"></i> @Localizer["Products"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Orders" asp-action="Manage">
                                <i class="bi bi-receipt me-1 text-success"></i> @Localizer["Orders"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Users" asp-action="Manage">
                                <i class="bi bi-people me-1 text-success"></i> @Localizer["Users"]
                            </a>
                        </li>
                    </ul>
                }

                <ul class="navbar-nav @(CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ar" ? "me-auto" : "ms-auto") align-items-center gap-2">

                    <li class="nav-item dropdown me-2">
                        <button class="btn btn-link text-white-50 text-decoration-none dropdown-toggle d-flex align-items-center gap-1 p-1" type="button" id="langDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate text-success fs-5"></i>
                            <span>@(CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ar" ? "العربية" : "English")</span>
                        </button>
                        <ul class="dropdown-menu shadow" aria-labelledby="langDropdown">
                            <li>
                                <form asp-controller="Language" asp-action="SetLanguage"
                                      asp-route-culture="en"
                                      asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                      method="post" class="m-0">
                                    <button type="submit" class="dropdown-item fw-medium">English</button>
                                </form>
                            </li>
                            <li>
                                <form asp-controller="Language" asp-action="SetLanguage"
                                      asp-route-culture="ar"
                                      asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString"
                                      method="post" class="m-0">
                                    <button type="submit" class="dropdown-item fw-medium">العربية</button>
                                </form>
                            </li>
                        </ul>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white-50 p-2 rounded-circle hover-icon position-relative"
                                   asp-controller="Wishlist" asp-action="Wishlist" title="@Localizer["Wishlist"]">
                                    <i class="bi bi-heart-fill fs-5 text-danger"></i>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white-50 p-2 rounded-circle hover-icon position-relative"
                                   asp-controller="Cart" asp-action="Cart" title="@Localizer["ShoppingCart"]">
                                    <i class="bi bi-cart3 fs-5 text-success"></i>
                                </a>
                            </li>
                        }

                        <div class="dropdown">
                            <button class="btn btn-link p-0 border-0 text-success text-decoration-none shadow-none dropdown-toggle-custom" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="bi bi-person-circle fs-3"></i>
                            </button>

                            <div class="dropdown-menu shadow" aria-labelledby="dropdownMenuButton">
                                <a class="dropdown-item d-flex align-items-center gap-2 fw-semibold fs-6" asp-controller="Profile" asp-action="MyProfile">
                                    <i class="bi bi-person fs-5 text-success"></i> @Localizer["MyProfile"]
                                </a>
                                <hr class="dropdown-divider">
                                @if (User.IsInRole("Customer"))
                                {
                                    <a class="dropdown-item d-flex align-items-center gap-2 fw-semibold fs-6"
                                       asp-controller="Orders" asp-action="Index">
                                        <i class="bi bi-bag-check fs-5 text-success"></i> @Localizer["MyOrders"]
                                    </a>
                                    <hr class="dropdown-divider">
                                }

                                <form asp-controller="Account" asp-action="Logout" method="post" class="p-2">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-semibold d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-box-arrow-right"></i> @Localizer["Logout"]
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white-50 px-3 fw-medium hover-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>@Localizer["Login"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-success btn-sm px-4 rounded-pill fw-semibold shadow-sm text-white border-0"
                               asp-controller="Account" asp-action="Register" style="background-color: #198754;">
                                @Localizer["SignUp"]
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="appToast" class="toast align-items-center text-white bg-dark border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-medium">
                    @TempData["NotifyMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["NotifyMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('appToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }
</body>
</html>