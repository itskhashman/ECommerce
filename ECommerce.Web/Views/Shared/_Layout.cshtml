<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Home">
                <i class="bi bi-cart4 me-2"></i>ECommerce
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Categories" asp-action="Index">
                                    <i class="bi bi-tags me-1 text-success"></i> Categories
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Products" asp-action="Index">
                                    <i class="bi bi-box-seam me-1 text-success"></i> Products
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Orders" asp-action="Manage">
                                    <i class="bi bi-receipt me-1 text-success"></i> Orders
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 rounded-2 text-white-50 hover-bg-dark" asp-controller="Users" asp-action="Manage">
                                    <i class="bi bi-people me-1 text-success"></i> Users
                                </a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <div class="me-auto"></div>
                    }

                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white-50 p-2 rounded-circle hover-icon position-relative"
                                   asp-controller="Orders" asp-action="Index" title="My Orders">
                                    <i class="bi bi-bag-check fs-5 text-success"></i>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white-50 p-2 rounded-circle hover-icon position-relative"
                                   asp-controller="Wishlist" asp-action="Wishlist" title="Wishlist">
                                    <i class="bi bi-heart-fill fs-5 text-danger"></i>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white-50 p-2 rounded-circle hover-icon position-relative"
                                   asp-controller="Cart" asp-action="Cart" title="Shopping Cart">
                                    <i class="bi bi-cart3 fs-5 text-success"></i>
                                </a>
                            </li>
                        }

                        <span class="vr bg-secondary opacity-25 my-2 mx-1 d-none d-lg-inline" style="height: 1.5rem;"></span>

                        <li class="nav-item">
                            <a class="nav-link p-2 rounded-circle hover-icon" asp-controller="Users" asp-action="Profile" title="My Profile">
                                <i class="bi bi-person-circle text-success fs-5"></i>
                            </a>
                        </li>

                        <li class="nav-item ms-1">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-pill fw-semibold d-flex align-items-center gap-1">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white-50 px-3 fw-medium hover-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-success btn-sm px-4 rounded-pill fw-semibold shadow-sm text-white border-0"
                               asp-controller="Account" asp-action="Register" style="background-color: #198754;">
                                Sign Up
                            </a>
                        </li>
                    }
                </ul>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="appToast" class="toast align-items-center text-white bg-dark border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-medium">
                    @TempData["NotifyMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["NotifyMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('appToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }
</body>
</html>