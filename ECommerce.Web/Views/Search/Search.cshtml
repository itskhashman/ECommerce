@model ECommerce.Web.Models.Home.SearchViewModel

<div class="container mt-5">
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8 text-center">
            <h2 class="fw-bold text-dark mb-3">Search Results</h2>
            <form method="get" asp-action="Search">
                <input type="hidden" name="minPrice" value="@Model.MinPrice" />
                <input type="hidden" name="maxPrice" value="@Model.MaxPrice" />
                <input type="hidden" name="inStockOnly" value="@Model.InStockOnly.ToString().ToLower()" />
                <input type="hidden" name="categoryId" value="@Model.CategoryId" />

                <div class="input-group input-group-lg shadow-sm rounded">
                    <input type="text"
                           name="searchString"
                           value="@Model.SearchString"
                           class="form-control border-secondary-subtle"
                           placeholder="Search for products" />
                    <button class="btn btn-primary px-4" type="submit">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <form method="get" asp-action="Search">

                <input type="hidden" name="searchString" value="@Model.SearchString" />

                <div class="card shadow-sm border-0 p-4 bg-white">
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <h5 class="fw-bold text-dark m-0">
                            <i class="bi bi-sliders2-vertical me-2 text-primary"></i>Filters
                        </h5>
                    </div>

                    <div class="mb-4">

                        <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-1">
                            <label class="form-label fw-bold text-dark fs-6 mb-0 ">Price</label>
                        </div>

                        <div class="d-flex gap-2 align-items-center">
                            <input type="number" name="minPrice" value="@Model.MinPrice" class="form-control form-control-sm" placeholder="Min" min="0">
                            <span class="text-muted">-</span>
                            <input type="number" name="maxPrice" value="@Model.MaxPrice" class="form-control form-control-sm" placeholder="Max" min="0">
                        </div>

                    </div>

                    <div class="mb-4">

                        <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-1"
                             data-bs-toggle="collapse"
                             data-bs-target="#categoryListWrapper"
                             style="cursor: pointer;">
                            <label class="form-label fw-bold text-dark fs-6 mb-0">Category</label>
                            <i class="bi bi-dash fs-5 fw-bold text-dark"></i>
                        </div>

                        <div class="collapse show" id="categoryListWrapper">
                            <div class="pt-1">

                                <div class="form-check mb-2">
                                    <input class="form-check-input border-secondary-subtle"
                                           type="radio"
                                           name="categoryId"
                                           id="cat_all"
                                           value=""
                                           @(Model.CategoryId == null ? "checked" : "")>
                                    <label class="form-check-label text-dark fw-medium small ps-1" for="cat_all">
                                        All Categories
                                    </label>
                                </div>

                                @foreach (var category in Model.Categories)
                                {
                                    var isChecked = Model.CategoryId == category.Id;

                                    <div class="form-check mb-2">
                                        <input class="form-check-input border-secondary-subtle"
                                               type="radio"
                                               name="categoryId"
                                               id="cat_@category.Id"
                                               value="@category.Id"
                                               @(isChecked ? "checked" : "")>
                                        <label class="form-check-label text-dark fw-medium small ps-1" for="cat_@category.Id">
                                            @category.NameEn
                                        </label>
                                    </div>
                                }

                            </div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small">Availability</label>
                        <div class="form-check mb-1">
                            <input class="form-check-input" type="checkbox" name="inStockOnly" value="true" id="inStock" @(Model.InStockOnly ? "checked" : "")>
                            <label class="form-check-label text-dark" for="inStock">In Stock Only</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-outline-primary w-100 btn-sm mt-3 fw-semibold">Apply Filters</button>
                </div>
            </form>
        </div>

        <div class="col-md-8  shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted small">Showing <strong>@Model.Products.Count()</strong> items</span>
                <a asp-controller="Home" asp-action="Home" class="btn btn-outline-secondary btn-sm px-3 rounded-pill">
                    <i class="bi bi-arrow-left me-1"></i> Back Home
                </a>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center p-5 shadow-sm border-0">
                    <h6 class="fw-bold">No items match your search.</h6>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                    @foreach (var product in Model.Products)
                    {
                        var mainImgUrl = product.ProductImages?.FirstOrDefault(i => i.IsMain)?.URL;
                        var firstPrice = product.Skus?.OrderBy(s => s.Price).FirstOrDefault()?.Price;

                        <div class="col">
                            <a asp-action="Details" asp-route-productId="@product.Id" class="card h-100 shadow-sm border-0 position-relative">
                                <div class="bg-light overflow-hidden" style="height: 200px;">
                                    @if (!string.IsNullOrEmpty(mainImgUrl))
                                    {
                                        <img src="@mainImgUrl" class="card-img-top w-100 h-100 object-fit-cover" alt="@product.NameEn" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-secondary opacity-50">
                                            <i class="bi bi-image fs-2"></i>
                                            <small class="mt-1 small">No Image</small>
                                        </div>
                                    }
                                </div>

                                <div class="card-body d-flex flex-column text-center p-3">
                                    <div>
                                        <h6 class="card-title text-dark fw-semibold mb-2 text-truncate" title="@product.NameEn">
                                            @product.NameEn
                                        </h6>
                                    </div>
                                    <div class="mt-2">
                                        <span class="fs-6 fw-bold text-primary">
                                            @(firstPrice.HasValue ? "JOD " + firstPrice.Value.ToString() : "JOD 0.00")
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>