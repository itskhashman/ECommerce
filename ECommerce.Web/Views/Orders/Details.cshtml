@model ECommerce.Application.DTOs.Order.OrderDto

<div class="container py-4">

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 shadow-sm border-0 mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <div>
                        <h4 class="mb-1">Order #@Model.OrderNumber</h4>
                        <span class="text-muted small">Placed on @Model.CreatedAt.ToString("dd MMMM yyyy, h:mm tt")</span>
                    </div>
                    @if (Model.IsDeleted)
                    {
                        <span class="badge rounded-pill bg-danger">Canceled</span>

                    }
                    else
                        @switch (Model.OrderStatusId)
                        {
                        case 1:
                            <span class="badge rounded-pill bg-warning text-dark">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 2:
                            <span class="badge rounded-pill bg-info text-dark">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 3:
                            <span class="badge rounded-pill bg-primary">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 4:
                            <span class="badge rounded-pill bg-success">@Model.OrderStatus?.NameEn</span>
                            break;
                        default:
                            break;
                    }
                </div>

                <h5 class="mb-3">Order Items</h5>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Product Name</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold text-dark d-block">@item.Sku?.Product?.NameEn</span>
                                        <span class="text-muted small">@item.Sku?.SkuCode</span>
                                    </td>
                                    <td class="text-center fw-semibold">@item.Quantity</td>
                                    <td class="text-end fw-bold text-dark">JOD @item.SubTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 shadow-sm border-0 mb-4 bg-light">
                <h5 class="mb-3">Payment Summary</h5>
                <hr class="my-2"/>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Total Paid:</span>
                    <h3 class="text-success font-monospace mb-0">JOD @Model.TotalAmount</h3>
                </div>
            </div>

        </div>
    </div>
</div>