@using System.Globalization
@model ECommerce.Application.DTOs.Order.OrderDto

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = $"{Localizer["OrderTitlePrefix"]} #{Model.OrderNumber}";
}

<div class="container py-4" dir="@(isArabic ? "rtl" : "ltr")">

    <div class="row mb-4">
        <div class="col-12">
            <div class="card p-4 shadow-sm border-0 bg-white">

                @if (Model.IsDeleted)
                {
                    <div class="alert alert-danger d-flex align-items-center mb-0 rounded-3 border-0 shadow-sm gap-3" role="alert">
                        <i class="bi bi-x-circle-fill fs-3 text-danger"></i>
                        <div>
                            <h6 class="fw-bold mb-1">@Localizer["OrderCanceledAlert"]</h6>
                        </div>
                    </div>
                }
                else
                {
                    int currentStatus = Model.OrderStatusId;

                    <div class="d-flex text-center justify-content-center pt-3 mx-auto w-100" style="max-width: 900px;">

                        <div class="flex-fill position-relative">
                            <div class="position-absolute top-0 start-0 translate-middle-y w-100" style="height: 4px; mt: 20px; z-index: 1; opacity: 0;"></div>

                            <div class="d-flex flex-column align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm bg-success text-white"
                                     style="width: 40px; height: 40px; font-size: 1.1rem; z-index: 2;">
                                    <i class="bi bi-receipt"></i>
                                </div>
                                <span class="small fw-bold mt-2 text-success">@Localizer["StatusStepPending"]</span>
                            </div>
                        </div>

                        <div class="flex-fill position-relative">
                            <div class="position-absolute start-0 w-100"
                                 style="height: 4px; top: 18px; @(isArabic ? "right: -50% !important;" : "left: -50% !important;") width: 100%; z-index: 1;
                                             background-color: @(currentStatus >= 2 ? "#198754" : "#e9ecef");">
                            </div>

                            <div class="d-flex flex-column align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm @(currentStatus >= 2 ? "bg-success text-white" : "bg-light text-muted border")"
                                     style="width: 40px; height: 40px; font-size: 1.1rem; z-index: 2;">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                                <span class="small fw-bold mt-2 @(currentStatus >= 2 ? "text-success" : "text-muted")">@Localizer["StatusStepProcessing"]</span>
                            </div>
                        </div>

                        <div class="flex-fill position-relative">
                            <div class="position-absolute start-0 w-100"
                                 style="height: 4px; top: 18px; @(isArabic ? "right: -50% !important;" : "left: -50% !important;") width: 100%; z-index: 1;
                                             background-color: @(currentStatus >= 3 ? "#198754" : "#e9ecef");">
                            </div>

                            <div class="d-flex flex-column align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm @(currentStatus >= 3 ? "bg-success text-white" : "bg-light text-muted border")"
                                     style="width: 40px; height: 40px; font-size: 1.1rem; z-index: 2;">
                                    <i class="bi bi-truck"></i>
                                </div>
                                <span class="small fw-bold mt-2 @(currentStatus >= 3 ? "text-success" : "text-muted")">@Localizer["StatusStepShipped"]</span>
                            </div>
                        </div>

                        <div class="flex-fill position-relative">
                            <div class="position-absolute start-0 w-100"
                                 style="height: 4px; top: 18px; @(isArabic ? "right: -50% !important;" : "left: -50% !important;") width: 100%; z-index: 1;
                                             background-color: @(currentStatus == 4 ? "#198754" : "#e9ecef");">
                            </div>

                            <div class="d-flex flex-column align-items-center">
                                <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm @(currentStatus == 4 ? "bg-success text-white" : "bg-light text-muted border")"
                                     style="width: 40px; height: 40px; font-size: 1.1rem; z-index: 2;">
                                    <i class="bi bi-house-check"></i>
                                </div>
                                <span class="small fw-bold mt-2 @(currentStatus == 4 ? "text-success" : "text-muted")">@Localizer["StatusStepDelivered"]</span>
                            </div>
                        </div>

                    </div>

                    <div class="text-center mt-4">
                        <span class="badge bg-light text-success border border-success-subtle px-3 py-2 rounded-pill small fw-bold shadow-sm">
                            <i class="bi bi-clock-history me-1"></i> @Localizer["PlacedAtPrefix"] @Model.CreatedAt.ToString(isArabic ? "dd MMMM yyyy, h:mm tt" : "dd MMMM yyyy, h:mm tt", CultureInfo.CurrentCulture)
                        </span>
                    </div>
                }

            </div>
        </div>
    </div>
    <div class="row g-4">

        <div class="col-lg-8">
            <div class="card p-4 shadow-sm border-0 mb-4 bg-white">

                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <div>
                        <h4 class="mb-1 text-dark fw-bold">@Localizer["OrderHeading"] #@Model.OrderNumber</h4>
                        <span class="text-muted small">@Localizer["ReferenceIdLabel"]: @Model.Id</span>
                    </div>

                    @if (Model.IsDeleted)
                    {
                        <span class="badge rounded-pill bg-danger px-3 py-2 text-uppercase">@Localizer["CanceledBadgeText"]</span>
                    }
                    else
                    {
                        @switch (Model.OrderStatusId)
                        {
                            case 1:
                                <span class="badge rounded-pill bg-warning text-dark px-3 py-2 fw-bold">
                                    @(isArabic? Model.OrderStatus?.NameAr : Model.OrderStatus?.NameEn)
                                </span>
                                break;
                            case 2:
                                <span class="badge rounded-pill bg-info text-dark px-3 py-2 fw-bold">
                                    @(isArabic? Model.OrderStatus?.NameAr : Model.OrderStatus?.NameEn)
                                </span>
                                break;
                            case 3:
                                <span class="badge rounded-pill bg-primary px-3 py-2 fw-bold">
                                    @(isArabic? Model.OrderStatus?.NameAr : Model.OrderStatus?.NameEn)
                                </span>
                                break;
                            case 4:
                                <span class="badge rounded-pill bg-success px-3 py-2 fw-bold">
                                    @(isArabic? Model.OrderStatus?.NameAr : Model.OrderStatus?.NameEn)
                                </span>
                                break;
                        }
                    }
                </div>

                <h5 class="mb-3 fw-bold text-dark">@Localizer["OrderItemsHeading"]</h5>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="border-0 text-muted small text-uppercase py-3 @(isArabic ? "text-start" : "")">@Localizer["ThProductName"]</th>
                                <th scope="col" class="border-0 text-muted small text-uppercase py-3 text-center">@Localizer["ThQuantity"]</th>
                                <th scope="col" class="border-0 text-muted small text-uppercase py-3 @(isArabic ? "text-start" : "text-end")">@Localizer["ThTotalPrice"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="py-3">
                                        <span class="fw-bold text-dark d-block mb-0">
                                            @(isArabic? item.Sku?.Product?.NameAr : item.Sku?.Product?.NameEn)
                                        </span>
                                        <span class="text-muted font-monospace small" style="font-size: 0.75rem;">@Localizer["SkuCodePrefix"]: @item.Sku?.SkuCode</span>
                                    </td>
                                    <td class="text-center fw-semibold text-dark py-3">@item.Quantity</td>
                                    <td class="fw-bold text-dark py-3 @(isArabic ? "text-start" : "text-end")">JOD @item.SubTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 shadow-sm border-0 mb-4 bg-light">

                <h5 class="mb-3 fw-bold text-dark">@Localizer["PaymentSummaryHeading"]</h5>
                <hr class="my-2 text-muted opacity-25" />

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="fw-bold text-secondary">@Localizer["TotalPaidLabel"]</span>
                    <h3 class="text-success font-monospace fw-bold mb-0">JOD @Model.TotalAmount.ToString("N2")</h3>
                </div>


            </div>
        </div>

    </div>
</div>