@model ECommerce.Application.DTOs.Order.OrderDto

<div class="container py-4">

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 shadow-sm border-0 mb-4">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <div>
                        <h4 class="mb-1">Order #@Model.OrderNumber</h4>
                        <span class="text-muted small">Placed on @Model.CreatedAt.ToString("dd MMMM yyyy, h:mm tt")</span>
                    </div>
                    @switch (Model.OrderStatus.Id)
                    {
                        case 1:
                            <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 2:
                            <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 py-2">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 3:
                            <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2">@Model.OrderStatus?.NameEn</span>
                            break;
                        case 4:
                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2">@Model.OrderStatus?.NameEn</span>
                            break;
                        default:
                            break;
                    }
                </div>

                <h5 class="mb-3">Order Items</h5>
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Product Name</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderItems != null && Model.OrderItems.Any())
                            {
                                foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <span class="fw-bold text-dark d-block">@item.Sku?.Product?.NameEn</span>
                                            <span class="text-muted small">@item.Sku?.SkuCode</span>
                                        </td>
                                        <td class="text-center">$@item.PriceAtPurchase</td>
                                        <td class="text-center fw-semibold">@item.Quantity</td>
                                        <td class="text-end fw-bold text-dark">JOD @item.SubTotal</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">No products mapped to this order record.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card p-4 shadow-sm border-0 mb-4 bg-light">
                <h5 class="mb-3">Payment Summary</h5>
                <hr class="my-2"/>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Total Paid:</span>
                    <h3 class="text-success font-monospace mb-0">JOD @Model.TotalAmount</h3>
                </div>
            </div>

        </div>
    </div>
</div>