@using System.Globalization
@model ECommerce.Application.DTOs.Order.OrderDto

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["SuccessPageTitle"];
}

<div class="container" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="row md-4">
        @await Html.PartialAsync("_CheckoutSteps", "Complete")
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-md-7 text-center">
            <div class="card p-5 border-success shadow-sm">
                <h1 class="text-success display-4">@Localizer["ThankYouHeader"]</h1>
                <p class="lead mt-3">@Localizer["SuccessSuccessMessage"]</p>
                <hr />
                <p class="mb-1">@Localizer["OrderReferenceLabel"]</p>
                <h4 class="text-dark font-monospace mb-4">@Model.OrderNumber</h4>

                <a asp-controller="Home" asp-action="Home" class="btn btn-outline-dark px-5 mt-3">
                    @Localizer["ContinueShoppingButton"]
                </a>
            </div>
        </div>
    </div>
</div>