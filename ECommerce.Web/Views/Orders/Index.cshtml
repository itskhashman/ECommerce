@model IEnumerable<ECommerce.Application.DTOs.Order.OrderDto>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Orders</h2>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Order Number</th>
                            <th>Date Placed</th>
                            <th>Total Amount</th>
                            <th>Status</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-dark">#@order.OrderNumber</td>
                                <td>@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="fw-semibold text-success">JOD @order.TotalAmount</td>
                                <td>
                                    @switch (order.OrderStatusId) 
                                    {
                                        case 1: 
                                                <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning px-3 py-2">@order.OrderStatus?.NameEn</span>
                                            break;
                                        case 2: 
                                                <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 py-2">@order.OrderStatus?.NameEn</span>
                                            break;
                                        case 3: 
                                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2">@order.OrderStatus?.NameEn</span>
                                            break;
                                        case 4:
                                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2">@order.OrderStatus?.NameEn</span>
                                            break;
                                        default:
                                            break;
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-success px-3 shadow-sm">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="text-muted">You haven't placed any orders yet!</h4>
            <p class="text-muted small">Your order history will appear here once you buy items.</p>
            <a href="/Home" class="btn btn-primary mt-3">Browse Products</a>
        </div>
    }
</div>