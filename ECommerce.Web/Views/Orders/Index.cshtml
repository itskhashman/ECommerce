@using System.Globalization
@model IEnumerable<ECommerce.Application.DTOs.Order.OrderDto>

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["MyOrdersTitle"];
}

<div class="container py-4" dir="@(isArabic ? "rtl" : "ltr")">

    @if (Model != null && Model.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">@Localizer["MyOrdersHeading"]</h2>
        </div>
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="@(isArabic ? "pe-3" : "ps-3")">@Localizer["ThOrderNumber"]</th>
                            <th>@Localizer["ThDatePlaced"]</th>
                            <th>@Localizer["ThTotalAmount"]</th>
                            <th>@Localizer["ThStatus"]</th>
                            <th class="@(isArabic ? "text-start ps-3" : "text-end pe-3")">@Localizer["ThActions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="@(isArabic ? "pe-3" : "ps-3") fw-bold text-dark">#@order.OrderNumber</td>
                                <td>@order.CreatedAt.ToString(isArabic ? "yyyy-MM-dd HH:mm" : "MMM dd, yyyy HH:mm", CultureInfo.CurrentCulture)</td>
                                <td class="fw-semibold text-success">JOD @order.TotalAmount.ToString("N2")</td>
                                <td>
                                    @if (order.IsDeleted)
                                    {
                                        <span class="badge rounded-pill bg-danger">@Localizer["CanceledStatusBadge"]</span>
                                    }
                                    else
                                    {
                                        @switch (order.OrderStatusId)
                                        {
                                            case 1:
                                                <span class="badge rounded-pill bg-warning text-dark">
                                                    @(isArabic? order.OrderStatus?.NameAr : order.OrderStatus?.NameEn)
                                                </span>
                                                break;
                                            case 2:
                                                <span class="badge rounded-pill bg-info text-dark">
                                                    @(isArabic? order.OrderStatus?.NameAr : order.OrderStatus?.NameEn)
                                                </span>
                                                break;
                                            case 3:
                                                <span class="badge rounded-pill bg-primary">
                                                    @(isArabic? order.OrderStatus?.NameAr : order.OrderStatus?.NameEn)
                                                </span>
                                                break;
                                            case 4:
                                                <span class="badge rounded-pill bg-success">
                                                    @(isArabic? order.OrderStatus?.NameAr : order.OrderStatus?.NameEn)
                                                </span>
                                                break;
                                            default:
                                                break;
                                        }
                                    }
                                </td>
                                <td class="@(isArabic ? "text-start ps-3" : "text-end pe-3")">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-success px-3 shadow-sm">
                                        @Localizer["ViewDetailsButton"]
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h4 class="fw-bold text-dark mb-2">@Localizer["EmptyOrdersMessage"]</h4>
            <a asp-controller="Home" asp-action="Home" class="btn btn-dark rounded-0 px-5 py-2 fw-bold text-uppercase mt-2">
                @Localizer["StartShoppingButton"]
            </a>
        </div>
    }
</div>