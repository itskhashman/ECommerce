@model IEnumerable<ECommerce.Application.DTOs.Order.OrderDto>


<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold m-0">Manage Orders</h2>
            <p class="text-muted small m-0">Manage your store orders</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 p-3">
        <div class="table-responsive">
            <table id="ordersTable" class="table table-striped table-hover align-middle mb-0" style="width:100%">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Date Placed</th>
                        <th>User</th>
                        <th>Total Amount</th>
                        <th>Current Status</th>
                        <th>Update Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr id="order-row-@order.Id">
                                <td class="fw-bold text-dark">#@order.OrderNumber</td>
                                <td class="small text-muted">
                                    @order.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                </td>
                                <td><span class="badge bg-light text-dark border">@order.User.FirstNameEn</span></td>
                                <td class="fw-semibold text-dark">JOD @order.TotalAmount</td>
                                <td>
                                    @switch (order.OrderStatusId)
                                    {
                                        case 1:
                                            <span id="badge-@order.Id" class="badge rounded-pill bg-warning text-dark">Pending</span>
                                            break;
                                        case 2:

                                            <span id="badge-@order.Id" class="badge rounded-pill bg-info text-dark">Confirmed</span>
                                            break;
                                        case 3:

                                            <span id="badge-@order.Id" class="badge rounded-pill bg-primary">Shipped</span>
                                            break;
                                        case 4:

                                            <span id="badge-@order.Id" class="badge rounded-pill bg-success">Delivered</span>
                                            break;
                                        default:
                                            break;
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm border-secondary-subtle" style="width: 140px;"
                                            onchange="updateOrderStatus(@order.Id, this.value)">
                                        <option value="1" selected="@(order.OrderStatusId == 1)">Pending</option>
                                        <option value="2" selected="@(order.OrderStatusId == 2)">Confirmed</option>
                                        <option value="3" selected="@(order.OrderStatusId == 3)">Shipped</option>
                                        <option value="4" selected="@(order.OrderStatusId == 4)">Delivered</option>
                                    </select>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group gap-2">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-success shadow-sm">
                                             View
                                        </a>
                                        <button class="btn btn-sm btn-danger shadow-sm" onclick="cancelOrder(@order.Id)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        let dataTableInstance;

        $(document).ready(function () {
            dataTableInstance = $('#ordersTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "order": [[1, "desc"]], 
                "columnDefs": [
                    { "orderable": false, "targets": [5, 6] } 
                ]
            });
        });

        async function updateOrderStatus(orderId, statusId) {
            try {
                const response = await fetch(`/api/Order/Edit/${orderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(parseInt(statusId))
                });

                const result = await response.json();
                if (response.ok && result.success) {
                    const badge = document.getElementById(`badge-${orderId}`);
                    badge.className = "badge rounded-pill";

                    if(statusId == 1) { badge.classList.add("bg-warning", "text-dark"); badge.innerText = "Pending"; }
                    else if(statusId == 2) { badge.classList.add("bg-info", "text-dark"); badge.innerText = "Confirmed"; }
                    else if(statusId == 3) { badge.classList.add("bg-primary"); badge.innerText = "Shipped"; }
                    else if(statusId == 4) { badge.classList.add("bg-success"); badge.innerText = "Delivered"; }

                    dataTableInstance.cell($(badge).closest('td')).invalidate().draw(false);
                } else {
                    alert("Error updating order status: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Failed to reach API framework endpoint.");
            }
        }

        async function cancelOrder(orderId) {
            if (!confirm("Are you sure you want to cancel and delete this order completely?")) return;

            try {
                const response = await fetch(`/api/Order/Delete/${orderId}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                if (response.ok && result.success) {    
                    const rowElement = document.getElementById(`order-row-${orderId}`);
                    dataTableInstance.row($(rowElement)).remove().draw(false);
                } else {
                    alert("Error: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Failed to delete order entry record.");
            }
        }
    </script>
}
