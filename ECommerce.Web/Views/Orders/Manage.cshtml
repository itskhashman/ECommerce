@using System.Globalization
@model IEnumerable<ECommerce.Application.DTOs.Order.OrderDto>

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["ManageOrdersTitle"];
}

<div class="container py-4" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold">@Localizer["ManageOrdersHeading"]</h2>
            <p class="text-muted small">@Localizer["ManageOrdersSubheading"]</p>
        </div>
    </div>

    <div class="card shadow-sm p-3">
        <div class="table-responsive">
            <table id="ordersTable" class="table table-striped table-hover align-middle mb-0 w-100">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold @(isArabic ? "pe-4 text-start" : "ps-4 text-start")" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThOrderNumber"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold text-start" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThDatePlaced"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold text-start" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThUser"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold text-start" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThTotalAmount"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold text-start" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThCurrentStatus"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold text-start" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThUpdateStatus"]</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold @(isArabic ? "ps-4 text-start" : "pe-4 text-end")" style="letter-spacing: 0.5px; font-size: 0.75rem;">@Localizer["ThActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr id="order-row-@order.Id">
                                <td class="fw-bold text-dark @(isArabic ? "pe-4" : "ps-4")">#@order.OrderNumber</td>
                                <td class="small text-muted">
                                    @order.CreatedAt.ToString(isArabic ? "yyyy-MM-dd HH:mm" : "yyyy-MM-dd HH:mm", CultureInfo.CurrentCulture)
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @(isArabic? order.User?.FirstNameAr : order.User?.FirstNameEn)
                                    </span>
                                </td>

                                <td class="fw-semibold text-dark">JOD @order.TotalAmount</td>
                                <td>
                                    @switch (order.OrderStatusId)
                                    {
                                        case 1:
                                            <span id="badge-@order.Id" class="badge rounded-pill bg-warning text-dark">@Localizer["StatusPending"]</span>
                                            break;
                                        case 2:
                                            <span id="badge-@order.Id" class="badge rounded-pill bg-info text-dark">@Localizer["StatusConfirmed"]</span>
                                            break;
                                        case 3:
                                            <span id="badge-@order.Id" class="badge rounded-pill bg-primary">@Localizer["StatusShipped"]</span>
                                            break;
                                        case 4:
                                            <span id="badge-@order.Id" class="badge rounded-pill bg-success">@Localizer["StatusDelivered"]</span>
                                            break;
                                        default:
                                            break;
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm border-secondary-subtle" style="width: 140px;"
                                            onchange="updateOrderStatus(@order.Id, this.value)">
                                        <option value="1" selected="@(order.OrderStatusId == 1)">@Localizer["StatusPending"]</option>
                                        <option value="2" selected="@(order.OrderStatusId == 2)">@Localizer["StatusConfirmed"]</option>
                                        <option value="3" selected="@(order.OrderStatusId == 3)">@Localizer["StatusShipped"]</option>
                                        <option value="4" selected="@(order.OrderStatusId == 4)">@Localizer["StatusDelivered"]</option>
                                    </select>
                                </td>
                                <td class="@(isArabic ? "ps-4 text-start" : "pe-4 text-end")">
                                    <div class="btn-group gap-2">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-success shadow-sm">
                                            @Localizer["ViewButton"]
                                        </a>
                                        <button class="btn btn-sm btn-danger shadow-sm" onclick="cancelOrder(@order.Id)">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {

    <script>
        let dataTableInstance;

        $(document).ready(function () {
            dataTableInstance = $('#ordersTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "order": [[1, "desc"]],
                "columnDefs": [
                    { "orderable": false, "targets": [5, 6] }
                ]
            });
        });

        async function updateOrderStatus(orderId, statusId) {
            try {
                const response = await fetch(`/api/Order/Edit/${orderId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(parseInt(statusId))
                });

                const result = await response.json();
                if (response.ok && result.success) {
                    const badge = document.getElementById(`badge-${orderId}`);
                    badge.className = "badge rounded-pill";

                    if(statusId == 1) { badge.classList.add("bg-warning", "text-dark"); badge.innerText = "Pending"; }
                    else if(statusId == 2) { badge.classList.add("bg-info", "text-dark"); badge.innerText = "Confirmed"; }
                    else if(statusId == 3) { badge.classList.add("bg-primary"); badge.innerText = "Shipped"; }
                    else if(statusId == 4) { badge.classList.add("bg-success"); badge.innerText = "Delivered"; }

                    dataTableInstance.cell($(badge).closest('td')).invalidate().draw(false);
                } else {
                    alert("Error updating order status: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Failed to reach API framework endpoint.");
            }
        }

        async function cancelOrder(orderId) {
            if (!confirm("Are you sure you want to cancel and delete this order completely?")) return;

            try {
                const response = await fetch(`/api/Order/Delete/${orderId}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                if (response.ok && result.success) {
                    const rowElement = document.getElementById(`order-row-${orderId}`);
                    dataTableInstance.row($(rowElement)).remove().draw(false);
                } else {
                    alert("Error: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Failed to delete order entry record.");
            }
        }
    </script>
}