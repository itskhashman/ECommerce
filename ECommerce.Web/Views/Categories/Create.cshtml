@model ECommerce.Application.DTOs.CreateCategoryDto

@{
    Layout = "_Layout";
}
<body>
    <div class="container mt-4" style="max-width: 600px;">
        <h2 class="mb-4">Create Category</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="shadow p-4 rounded bg-light">

            <div class="mb-3">
                <label asp-for="NameAr" class="form-label fw-bold">Arabic Name <span class="text-danger">*</span></label>
                <input asp-for="NameAr" class="form-control" placeholder="Enter Arabic name..." />
                <span asp-validation-for="NameAr" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NameEn" class="form-label fw-bold">English Name <span class="text-danger">*</span></label>
                <input asp-for="NameEn" class="form-control" placeholder="Enter English name..." />
                <span asp-validation-for="NameEn" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label fw-bold">Upload Image</label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParentCategoryId" class="form-label fw-bold">Parent Category (Optional)</label>
                <select asp-for="ParentCategoryId" asp-items="ViewBag.ParentCategories" class="form-select">
                    <option value="">-- Main Category --</option>
                </select>
                <span asp-validation-for="ParentCategoryId" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
                <span asp-validation-for="IsActive" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">Save</button>
                <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
            </div>
        </form>
    </div>
</body>