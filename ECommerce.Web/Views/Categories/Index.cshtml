@model IEnumerable<ECommerce.Application.DTOs.Category.CategoryDto>
@{
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold">Manage Categories</h2>
            <p class="text-muted small">Manage your application product categories</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 shadow-sm fw-medium">
            Add Category
        </a>
    </div>

    <div class="card shadow-sm p-3">
        <div class="table-responsive">
            <table id="categoriesTable" class="table table-striped table-hover align-middle mb-0 w-100">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="py-3 px-4 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Name</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Image</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Active Status</th>
                        <th class="py-3 px-4 text-secondary text-uppercase fs-7 fw-bold text-end" style="letter-spacing: 0.5px; font-size: 0.75rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var parent in Model)
                        {
                            <tr class="table-secondary bg-opacity-10">
                                <td class="fw-bold text-dark">
                                    <i class="bi bi-folder-fill text-primary me-2"></i>
                                    @parent.NameEn
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(parent.ImageUrl))
                                    {
                                        <img src="@parent.ImageUrl"
                                             width="60"
                                             height="45"
                                             class="rounded border shadow-sm"
                                             style="object-fit:cover;" />
                                    }
                                </td>
                                <td>
                                    @if (parent.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group gap-2 justify-content-end">
                                        <a asp-action="Edit" asp-route-id="@parent.Id" class="btn btn-sm btn-success shadow-sm">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@parent.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-danger shadow-sm">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>

                            foreach (var child in parent.Children)
                            {
                                <tr>
                                    <td class="ps-5 text-dark">
                                        <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                        @child.NameEn
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(child.ImageUrl))
                                        {
                                            <img src="@child.ImageUrl"
                                                 width="40"
                                                 height="40"
                                                 class="rounded-5 border shadow-sm"
                                                 style="object-fit:cover;" />
                                        }
                                    </td>
                                    <td>
                                        @if (child.IsActive)
                                        {
                                            <span class="badge rounded-pill bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group gap-2 justify-content-end">
                                            <a asp-action="Edit" asp-route-id="@child.Id" class="btn btn-sm btn-success shadow-sm">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@child.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" class="m-0">
                                                <button type="submit" class="btn btn-sm btn-danger shadow-sm">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#categoriesTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": false,
                "info": true,
                "autoWidth": false,
                "responsive": true
            });
        });
    </script>
}