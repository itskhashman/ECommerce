@model IEnumerable<ECommerce.Application.DTOs.Category.CategoryDto>
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold m-0">Categories</h2>
            <p class="text-muted small m-0">Manage your application product categories</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 shadow-sm fw-medium">
            Add Category
        </a>
    </div>

    <div class="card shadow-sm border-0 bg-white rounded-3 overflow-hidden p-3">
        <div class="table-responsive">
            <table id="categoriesTable" class="table table-hover align-middle m-0 w-100">
                <thead class="table-light border-bottom">
                    <tr>
                        <th class="py-3 px-4 text-secondary uppercase fs-7 fw-bold">Name</th>
                        <th class="py-3 text-secondary uppercase fs-7 fw-bold">Image</th>
                        <th class="py-3 text-secondary uppercase fs-7 fw-bold">Active</th>
                        <th class="py-3 px-4 text-secondary uppercase fs-7 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="d-block mb-2 fs-5">No categories found</span>
                            </td>
                        </tr>
                    }
                    @foreach (var parent in Model)
                    {
                        <tr class="table-secondary bg-opacity-10">

                            <td class="py-3 px-4 fw-bold text-dark">
                                <i class="bi bi-folder-fill text-primary me-2"></i>
                                @parent.NameEn
                            </td>

                            <td class="py-3">
                                @if (!string.IsNullOrEmpty(parent.ImageUrl))
                                {
                                    <img src="@parent.ImageUrl"
                                         width="60"
                                         height="45"
                                         class="rounded border shadow-sm"
                                         style="object-fit:cover;" />
                                }
                            </td>

                            <td class="py-3">
                                @if (parent.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 rounded-pill fw-medium">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2.5 py-1.5 rounded-pill fw-medium">Inactive</span>
                                }
                            </td>

                            <td class="py-3 px-4 text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@parent.Id" class="btn btn-light btn-sm px-3 border fw-medium shadow-sm">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@parent.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" class="m-0">
                                        <button type="submit" class="btn btn-outline-danger btn-sm px-3 fw-medium shadow-sm">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>

                        @foreach (var child in parent.Children)
                        {
                            <tr>

                                <td class="py-3 ps-5">
                                    <i class="bi bi-arrow-return-right text-muted me-2"></i>
                                    @child.NameEn
                                </td>

                                <td class="py-3 px-3">
                                    @if (!string.IsNullOrEmpty(child.ImageUrl))
                                    {
                                        <img src="@child.ImageUrl"
                                             width="40"
                                             height="40"
                                             class="rounded-5 border shadow-sm"
                                             style="" />
                                    }
                                </td>

                                <td class="py-3">
                                    @if (child.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 rounded-pill fw-medium">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2.5 py-1.5 rounded-pill fw-medium">Inactive</span>
                                    }
                                </td>

                                <td class="py-3 px-4 text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@child.Id" class="btn btn-light btn-sm px-3 border fw-medium shadow-sm">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@child.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" class="m-0">
                                            <button type="submit" class="btn btn-outline-danger btn-sm px-3 fw-medium shadow-sm">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }}
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#categoriesTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": false,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "dom": "<'row mb-3'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-5'i><'col-sm-7 text-end'p>>",
                "columnDefs": [
                    { "orderable": true, "targets": [] }
                ]
            });
        });
    </script>
}