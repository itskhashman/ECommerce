@model ECommerce.Application.DTOs.UpdateCategoryDto

@{
    Layout = "_Layout";
}

<div class="container mt-4" style="max-width: 600px;">
    <h2 class="mb-4 fw-bold text-dark">Edit Category</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="shadow-sm p-4 rounded-3 bg-white border">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <input type="hidden" asp-for="ImageUrl" />

        <div class="mb-3">
            <label asp-for="NameAr" class="form-label fw-bold">Arabic Name <span class="text-danger">*</span></label>
            <input asp-for="NameAr" class="form-control" />
            <span asp-validation-for="NameAr" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NameEn" class="form-label fw-bold">English Name <span class="text-danger">*</span></label>
            <input asp-for="NameEn" class="form-control" />
            <span asp-validation-for="NameEn" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ImageFile" class="form-label fw-bold">Category Image <span class="text-danger">*</span></label>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="mb-2">
                    <small class="text-muted d-block mb-1">Current Image:</small>
                    <img src="@Model.ImageUrl" width="100" height="70" style="object-fit: cover;" class="img-thumbnail rounded shadow-sm" alt="Current Category Image" />
                </div>
            }

            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
            <div class="form-text small text-muted">Leave empty to keep the current image.</div>
        </div>

        <div class="mb-3">
            <label asp-for="ParentCategoryId" class="form-label fw-bold">Parent Category <span class="text-danger">*</span></label>
            <select asp-for="ParentCategoryId" asp-items="ViewBag.ParentCategories" class="form-select">
                <option value="">-- Main Category --</option>
            </select>
            <span asp-validation-for="ParentCategoryId" class="text-danger small"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning px-4 text-white fw-medium shadow-sm">Save Changes</button>
            <a asp-action="Index" class="btn btn-light border px-4 fw-medium shadow-sm">Cancel</a>
        </div>
    </form>
</div>