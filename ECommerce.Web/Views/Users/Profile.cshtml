@using ECommerce.Application.DTOs.Lookups
@model ECommerce.Application.DTOs.User.UserDto

@{
    ViewData["Title"] = "My Profile";
}

<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
    <div id="actionToast" class="toast align-items-center text-white border-0 rounded-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage">
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="container my-5">
    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border rounded-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 font-monospace"
                         style="width: 80px; height: 80px; font-size: 1.5rem; font-weight: bold;">
                        @(Model?.FirstNameEn?[..1].ToUpper())@(Model?.LastNameEn?[..1].ToUpper())
                    </div>

                    <h5 class="fw-bold mb-1 text-dark" id="display-full-name">@Model?.FirstNameEn @Model?.LastNameEn</h5>
                    <p class="text-secondary small mb-3">@Model?.Email</p>

                    <span class="badge @(Model?.IsActive == true ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") rounded-pill px-3 py-1 small fw-normal">
                        @(Model?.IsActive == true ? "Active Account" : "Suspended")
                    </span>

                    <hr class="my-4">

                    <div class="text-start small text-muted">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Phone:</span>
                            <span class="text-dark font-monospace" id="display-phone">@Model?.Phone</span>
                        </div>
                        @if (Model?.LastLoginAt.HasValue == true)
                        {
                            <div class="d-flex justify-content-between">
                                <span>Last Login:</span>
                                <span class="text-dark font-monospace">@Model.LastLoginAt.Value.ToString("g")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
            {
                <div class="list-group rounded-0 shadow-sm mt-3 small">
                    <a asp-controller="Orders" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                        <span>📦 My Orders</span>
                        <i class="bi bi-chevron-right small text-muted"></i>
                    </a>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="card border rounded-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-dark text-uppercase fs-6">Personal Profile Details</h5>
                    <button class="btn btn-sm btn-outline-dark rounded-0 px-3 py-1 fw-bold text-uppercase small" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                        <i class="bi bi-pencil-square"></i> Edit Info
                    </button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">Full Name (English)</label>
                            <p class="pb-2 text-dark font-monospace" id="display-name-en">
                                @Model?.FirstNameEn @Model?.MiddleNameEn @Model?.LastNameEn
                            </p>
                        </div>

                        <div class="col-md-6 text-end" dir="rtl">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">الاسم الكامل (بالعربي)</label>
                            <p class="pb-2 text-dark font-monospace" id="display-name-ar">
                                @Model?.FirstNameAr @Model?.MiddleNameAr @Model?.LastNameAr
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
            {
                <div id="addresses-section" class="card border rounded-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                        <h5 class="m-0 fw-bold text-dark text-uppercase fs-6">Saved Shipping Addresses</h5>
                        <button type="button" class="btn btn-sm btn-dark rounded-0 px-3 py-1 fw-bold text-uppercase small" onclick="openAddressModalForAdd()">
                            + Add Address
                        </button>
                    </div>
                    <div class="card-body p-4">
                        @if (Model?.Address == null || !Model.Address.Any())
                        {
                            <div class="text-center py-4">
                                <p class="text-secondary small mb-0">You don't have any saved shipping addresses yet.</p>
                            </div>
                        }
                        else
                        {
                            <div class="row g-3">
                                @foreach (var address in Model.Address)
                                {
                                    <div class="col-md-6" id="address-card-@address.Id">
                                        <div class="card h-100 rounded-0 p-3 border position-relative @(address.IsDefault ? "border-dark shadow-sm" : "text-secondary")">

                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <span class="fw-bold text-dark text-uppercase small bg-light px-2 py-1 border border-secondary-subtle address-label">
                                                    @(string.IsNullOrWhiteSpace(address.Label) ? "Address" : address.Label)
                                                </span>

                                                @if (address.IsDefault)
                                                {
                                                    <span class="badge bg-dark text-white rounded-0 px-2 py-1 small fw-normal">
                                                        Default
                                                    </span>
                                                }
                                            </div>

                                            <div class="small text-dark lh-sm my-2">
                                                <p class="mb-1"><i class="bi bi-geo-alt-fill text-muted me-1"></i> <span class="address-street">@address.Street</span></p>
                                                <p class="mb-1 text-muted">
                                                    @if (address.City != null)
                                                    {
                                                        <span class="address-city" data-city-id="@address.CityId">@address.City.NameEn, @address.City.Country?.NameEn</span>
                                                    }
                                                </p>
                                                <p class="mb-0 text-muted">Postal Code: <span class="font-monospace address-postalcode">@address.PostalCode</span></p>
                                            </div>

                                            <div class="mt-3 pt-2 border-top d-flex justify-content-end gap-3 small">
                                                <button type="button" class="btn btn-link p-0 text-decoration-none text-secondary hover-dark small"
                                                        onclick="openAddressModalForEdit('@address.Id', '@address.Label', '@address.Street', '@address.CityId', '@address.PostalCode', '@address.IsDefault.ToString().ToLower()')">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </button>
                                                @if (!address.IsDefault)
                                                {
                                                    <button type="button" class="btn btn-link p-0 text-decoration-none text-danger small"
                                                            onclick="deleteAddressEntry('@Model.Id', '@address.Id')">
                                                        <i class="bi bi-trash3"></i> Delete
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="editProfileModal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-0 border shadow">
            <div class="modal-header bg-light border-bottom rounded-0 py-3">
                <h5 class="modal-title fw-bold text-uppercase small text-dark" id="editProfileModalLabel">Edit Profile Info</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editProfileForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="profileUserId" value="@Model?.Id" />

                    <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-1 mb-3">English Details</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted mb-1">First Name</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profFirstEn" value="@Model?.FirstNameEn" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted mb-1">Middle Name</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profMiddleEn" value="@Model?.MiddleNameEn" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted mb-1">Last Name</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profLastEn" value="@Model?.LastNameEn" required />
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-1 mb-3 text-end" dir="rtl">تفاصيل اللغة العربية</h6>
                    <div class="row g-3 mb-4" dir="rtl">
                        <div class="col-md-4 text-end">
                            <label class="form-label small fw-bold text-muted mb-1">الاسم الأول</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profFirstAr" value="@Model?.FirstNameAr" required />
                        </div>
                        <div class="col-md-4 text-end">
                            <label class="form-label small fw-bold text-muted mb-1">اسم الأب</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profMiddleAr" value="@Model?.MiddleNameAr" />
                        </div>
                        <div class="col-md-4 text-end">
                            <label class="form-label small fw-bold text-muted mb-1">العائلة / اللقب</label>
                            <input type="text" class="form-control rounded-0 small font-monospace" id="profLastAr" value="@Model?.LastNameAr" required />
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-1 mb-3">Contact Configuration</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted mb-1">Phone Number</label>
                            <input type="tel" class="form-control rounded-0 small font-monospace" id="profPhone" value="@Model?.Phone" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top rounded-0 py-2 px-4">
                    <button type="button" class="btn btn-outline-secondary rounded-0 small fw-bold text-uppercase px-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-dark rounded-0 small fw-bold text-uppercase px-4" id="editProfileSubmitBtn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer"))
{
    <div class="modal fade" id="addressModal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="addressModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0 border shadow">
                <div class="modal-header bg-light border-bottom rounded-0 py-3">
                    <h5 class="modal-title fw-bold text-uppercase small text-dark" id="addressModalLabel">Manage Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="addressForm">
                    <div class="modal-body p-4">
                        <input type="hidden" id="addrId" value="" />
                        <input type="hidden" id="addrUserId" value="@Model?.Id" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Address Tag / Label</label>
                            <input type="text" class="form-control rounded-0 small" id="addrLabel" placeholder="e.g. Home, Office, Gym" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Street Address</label>
                            <input type="text" class="form-control rounded-0 small" id="addrStreet" placeholder="Building Name, Apt No, Street details" required />
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label class="form-label small fw-bold text-secondary text-uppercase mb-1">City</label>
                                <select class="form-select rounded-0 small" id="addrCityId" required>
                                    <option value="" disabled selected>-- Select City --</option>
                                    @if (ViewBag.Cities != null)
                                    {
                                        foreach (var city in (IEnumerable<CityDto>)ViewBag.Cities)
                                        {
                                            <option value="@city.Id">@city.NameEn, @city.Country?.NameEn</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Postal Code</label>
                                <input type="text" class="form-control rounded-0 small font-monospace" id="addrPostalCode" placeholder="11110" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light border-top rounded-0 py-2 px-4">
                        <button type="button" class="btn btn-outline-secondary rounded-0 small fw-bold text-uppercase px-3" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-dark rounded-0 small fw-bold text-uppercase px-4" id="addressSubmitBtn">Save Address</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        let addressBootstrapModal = null;
        let editProfileBootstrapModal = null;

        const addressModalEl = document.getElementById('addressModal');
        const editProfileModalEl = document.getElementById('editProfileModal');

        document.addEventListener("DOMContentLoaded", () => {
            if (addressModalEl) {
                addressBootstrapModal = new bootstrap.Modal(addressModalEl);
            }
            if (editProfileModalEl) {
                editProfileBootstrapModal = new bootstrap.Modal(editProfileModalEl);
            }
        });

        function openAddressModalForAdd() {
            document.getElementById('addressForm').reset();
            document.getElementById('addrId').value = "";
            document.getElementById('addressModalLabel').innerText = "Add New Shipping Address";
            document.getElementById('addressSubmitBtn').innerText = "Create Address";
            addressBootstrapModal.show();
        }

        function openAddressModalForEdit(id, label, street, cityId, postalCode, isDefault) {
            document.getElementById('addressForm').reset();
            document.getElementById('addrId').value = id;
            document.getElementById('addrLabel').value = label === "Address" ? "" : label;
            document.getElementById('addrStreet').value = street;
            document.getElementById('addrCityId').value = cityId;
            document.getElementById('addrPostalCode').value = postalCode;

            document.getElementById('addressModalLabel').innerText = "Modify Shipping Address";
            document.getElementById('addressSubmitBtn').innerText = "Update Details";
            addressBootstrapModal.show();
        }

        document.getElementById('editProfileForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const userId = parseInt(document.getElementById('profileUserId').value) || 0;
            const payload = {
                Id: userId,
                FirstNameEn: document.getElementById('profFirstEn').value,
                MiddleNameEn: document.getElementById('profMiddleEn').value,
                LastNameEn: document.getElementById('profLastEn').value,
                FirstNameAr: document.getElementById('profFirstAr').value,
                MiddleNameAr: document.getElementById('profMiddleAr').value,
                LastNameAr: document.getElementById('profLastAr').value,
                Phone: document.getElementById('profPhone').value
            };

            const profileApiEndpoint = `/api/User/Edit/${userId}`;

            try {
                const response = await fetch(profileApiEndpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                const isSuccessful = result.success === true || result.Success === true;

                if (response.ok && isSuccessful) {
                    if (editProfileBootstrapModal) {
                        editProfileBootstrapModal.hide();
                    }

                    const serverMessage = result.message || result.Message || "Profile details updated successfully!";
                    alert(serverMessage);

                    window.location.reload();
                } else {
                    const serverMessage = result.message || result.Message || "Failed to update profile parameters.";
                    alert(serverMessage);
                }
            } catch (err) {
                console.error("Error updating user profile details:", err);
            }
        });

        if (addressModalEl) {
            document.getElementById('addressForm').addEventListener('submit', async function (e) {
                e.preventDefault();

                const idValue = document.getElementById('addrId').value;
                const isEditMode = idValue !== "";
                const userId = parseInt(document.getElementById('addrUserId').value) || 0;

                const payload = {
                    id: isEditMode ? parseInt(idValue) : 0,
                    userId: userId,
                    label: document.getElementById('addrLabel').value,
                    street: document.getElementById('addrStreet').value,
                    cityId: parseInt(document.getElementById('addrCityId').value) || 0,
                    postalCode: document.getElementById('addrPostalCode').value
                };

                const dynamicEndpoint = isEditMode
                    ? `/api/Address/Edit/${userId}`
                    : `/api/Address/Add/${userId}`;
                try {
                    const response = await fetch(dynamicEndpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    const result = await response.json();
                    const isSuccessful = result.success === true || result.Success === true;

                    if (response.ok && isSuccessful) {
                        addressBootstrapModal.hide();
                        alert(isEditMode ? "Address modified successfully!" : "New address saved successfully!");
                        window.location.reload();
                    } else {
                        const serverMessage = result.message || result.Message || "An error occurred saving your entry.";
                        alert(serverMessage);
                    }
                } catch (err) {
                    console.error("Exception managing address entries:", err);
                }
            });
        }

        async function deleteAddressEntry(userId, addressId) {
            if (!confirm("Are you sure you want to permanently delete this address?")) {
                return;
            }

            try {
                const response = await fetch(`/api/Address/Delete/${userId}/${addressId}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                const isSuccessful = result.success === true || result.Success === true;

                if (response.ok && isSuccessful) {
                    alert("Address profile deleted successfully!");

                    const cardElement = document.getElementById(`address-card-${addressId}`);
                    if (cardElement) {
                        cardElement.style.transition = "all 0.4s ease";
                        cardElement.style.opacity = "0";
                    }
                    window.location.reload();
                } else {
                    const serverMessage = result.message || result.Message || "Failed to complete deletion routing workflow.";
                }
            } catch (err) {
                console.error("Error deleting shipping address parameters:", err);
            }
        }
    </script>
}