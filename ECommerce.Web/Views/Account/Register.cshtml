@model ECommerce.Web.Models.ViewModels.RegisterViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>Create Account إنشاء حساب</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <label asp-for="FirstNameEn" class="form-label">First Name (EN)</label>
                                <input asp-for="FirstNameEn" class="form-label" />
                                <span asp-validation-for="FirstNameEn" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MiddleNameEn" class="form-label">Middle Name (EN)</label>
                                <input asp-for="MiddleNameEn" class="form-label" />
                                <span asp-validation-for="MiddleNameEn" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastNameEn" class="form-label">Last Name (EN)</label>
                                <input asp-for="LastNameEn" class="form-control" />
                                <span asp-validation-for="LastNameEn" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-3 text-end" dir="rtl">
                            <div class="col-md-6">
                                <label asp-for="FirstNameAr" class="form-label">الاسم الأول</label>
                                <input asp-for="FirstNameAr" class="form-control" />
                                <span asp-validation-for="FirstNameAr" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="MiddleNameAr" class="form-label">الاسم الأوسط</label>
                                <input asp-for="MiddleNameAr" class="form-control" />
                                <span asp-validation-for="MiddleNameAr" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="LastNameAr" class="form-label">الاسم الأخير</label>
                                <input asp-for="LastNameAr" class="form-control" />
                                <span asp-validation-for="LastNameAr" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label">Password</label>
                                <input asp-for="Password" type="password" class="form-control" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label">Phone</label>
                                <input asp-for="Phone" class="form-control" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                        </div>


                        <button type="submit" class="btn btn-primary w-100 mt-4">Register | تسجيل</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>