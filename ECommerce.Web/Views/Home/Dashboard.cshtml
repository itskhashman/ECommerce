@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model ECommerce.Application.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = Localizer["AdminDashboardTitle"];
    var isRtl = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}

<div class="container-fluid py-4">

    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card border-primary border-2 p-3 shadow-sm h-100">
                <div class="d-flex flex-row justify-content-between align-items-center">
                    <div class="text-secondary">
                        <h6 class="text-uppercase tracking-wider small fw-semibold mb-1">@Localizer["TotalRevenue"]</h6>
                        <h3 class="text-dark fw-bold mb-0">
                            @Model.TotalSales <span class="fw-bold fs-6">@Localizer["Currency"]</span>
                        </h3>
                    </div>
                    <div class="text-primary rounded p-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-currency-dollar fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success border-2 p-3 shadow-sm h-100">
                <div class="d-flex flex-row justify-content-between align-items-center">
                    <div class="text-secondary">
                        <h6 class="text-uppercase tracking-wider small fw-semibold mb-1">@Localizer["TotalOrders"]</h6>
                        <h3 class="text-dark fw-bold mb-0">@Model.TotalOrders</h3>
                    </div>
                    <div class="text-success rounded p-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-cart-check fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger border-2 p-3 shadow-sm h-100">
                <div class="d-flex flex-row justify-content-between align-items-center">
                    <div class="text-secondary">
                        <h6 class="text-uppercase tracking-wider small fw-semibold mb-1">@Localizer["TotalProducts"]</h6>
                        <h3 class="text-dark fw-bold mb-0">@Model.TotalProducts</h3>
                    </div>
                    <div class="text-danger rounded p-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-warning border-2 p-3 shadow-sm h-100">
                <div class="d-flex flex-row justify-content-between align-items-center">
                    <div class="text-secondary">
                        <h6 class="text-uppercase tracking-wider small fw-semibold mb-1">@Localizer["TotalActiveUsers"]</h6>
                        <h3 class="text-dark fw-bold mb-0">@Model.TotalUsers</h3>
                    </div>
                    <div class="text-warning rounded p-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <hr />

    <h4 class="mb-3">@Localizer["OrdersHeading"]</h4>

    <div class="row mb-4 text-center g-2">
        <div class="col @(isRtl ? "border-start" : "border-end")">
            <strong>@Localizer["StatusPending"]:</strong> <span class="badge bg-secondary">@Model.OrdersPending</span>
        </div>
        <div class="col @(isRtl ? "border-start" : "border-end")">
            <strong>@Localizer["StatusConfirmed"]:</strong> <span class="badge bg-primary">@Model.OrdersConfirmed</span>
        </div>
        <div class="col @(isRtl ? "border-start" : "border-end")">
            <strong>@Localizer["StatusShipped"]:</strong> <span class="badge bg-info">@Model.OrdersShipped</span>
        </div>
        <div class="col @(isRtl ? "border-start" : "border-end")">
            <strong>@Localizer["StatusDelivered"]:</strong> <span class="badge bg-success">@Model.OrdersDelivered</span>
        </div>
        <div class="col">
            <strong>@Localizer["StatusCancelled"]:</strong> <span class="badge bg-danger">@Model.OrdersCancelled</span>
        </div>
    </div>
    <hr />

    <div class="row mb-4">
        <div class="col-md-8 mb-3 mb-md-0">
            <div class="card p-3 shadow-sm h-100">
                <h5 class="fw-bold mb-3 text-secondary">@Localizer["LastWeekOrdersChartTitle"]</h5>
                <div style="position: relative; height:300px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm h-100">
                <h5 class="fw-bold mb-3 text-secondary">@Localizer["FulfillmentStatusChartTitle"]</h5>
                <div style="position: relative; height:300px;" class="d-flex align-items-center justify-content-center">
                    <canvas id="orderStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-4">
            <div class="card p-3 shadow-sm">
                <h4 class="fw-bold mb-3">@Localizer["RecentOrders"]</h4>
                <div class="table-responsive">
                    <table class="table table-hover m-0">
                        <thead>
                            <tr>
                                <th>@Localizer["ThOrderId"]</th>
                                <th>@Localizer["ThTotal"]</th>
                                <th>@Localizer["ThDate"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentOrders != null && Model.RecentOrders.Any())
                            {
                                foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td>#@order?.Id</td>
                                        <td>@Localizer["Currency"] @order?.TotalAmount.ToString("N2")</td>
                                        <td><span class="badge bg-dark">@order?.CreatedAt.ToString("g")</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-muted text-center py-3">@Localizer["NoOrdersFound"]</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card p-3 shadow-sm h-100">
                <h4 class="fw-bold mb-3">@Localizer["TopCategories"]</h4>
                <div class="table-responsive">
                    <table class="table table-striped m-0">
                        <thead>
                            <tr>
                                <th>@Localizer["ThCategoryName"]</th>
                                <th>@Localizer["ThTotalSold"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopCategories != null && Model.TopCategories.Any())
                            {
                                foreach (var category in Model.TopCategories)
                                {
                                    var localizedCatName = isRtl ? category.Value.NameAr : category.Value.NameEn;
                                    <tr>
                                        <td>@localizedCatName</td>
                                        <td>@category.Key</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-muted text-center py-3">@Localizer["NoSalesDataYet"]</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card p-3 shadow-sm h-100">
                <h4 class="fw-bold mb-3">@Localizer["TopProducts"]</h4>
                <div class="table-responsive">
                    <table class="table table-striped m-0">
                        <thead>
                            <tr>
                                <th>@Localizer["ThProductName"]</th>
                                <th>@Localizer["ThTotalSold"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProducts != null && Model.TopProducts.Any())
                            {
                                foreach (var product in Model.TopProducts)
                                {
                                    var localizedProdName = isRtl ? product.Value.NameAr : product.Value.NameEn;
                                    <tr>
                                        <td>@localizedProdName</td>
                                        <td>@product.Key</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-muted text-center py-3">@Localizer["NoSalesDataYet"]</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const isRtlMode = @(isRtl ? "true" : "false");

            @{
                    var today = DateTime.UtcNow.Date;
                    var last7Days = Enumerable.Range(0, 7)
                                    .Select(i => today.AddDays(-6 + i))
                                    .ToList();

                    var chartLabels = last7Days.Select(d => d.ToString("ddd (MM/dd)", CultureInfo.CurrentCulture)).ToList();

                    var chartData = last7Days.Select(d => Model.OrdersLastWeek != null && Model.OrdersLastWeek.ContainsKey(d)
                                    ? Model.OrdersLastWeek[d]
                                    : 0).ToList();
            }

            const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctxRevenue, {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartLabels)),
                    datasets: [{
                        label: '@Localizer["ChartDatasetLabelOrders"]',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartData)),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.08)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3,
                        pointBackgroundColor: '#0d6efd',
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    rtl: isRtlMode,
                    plugins: {
                        legend: {
                            rtl: isRtlMode,
                            labels: { textDirection: isRtlMode ? 'rtl' : 'ltr' }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            position: isRtlMode ? 'right' : 'left', 
                            ticks: { stepSize: 1, precision: 0 }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });

            const ctxOrder = document.getElementById('orderStatusChart').getContext('2d');
            new Chart(ctxOrder, {
                type: 'doughnut',
                data: {
                    labels: [
                        '@Localizer["StatusPending"]',
                        '@Localizer["StatusConfirmed"]',
                        '@Localizer["StatusShipped"]',
                        '@Localizer["StatusDelivered"]',
                        '@Localizer["StatusCancelled"]'
                    ],
                    datasets: [{
                        data: [
                            @Model.OrdersPending,
                            @Model.OrdersConfirmed,
                            @Model.OrdersShipped,
                            @Model.OrdersDelivered,
                            @Model.OrdersCancelled
                        ],
                        backgroundColor: ['#6c757d', '#0d6efd', '#0dcaf0', '#198754', '#dc3545'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            rtl: isRtlMode,
                            labels: {
                                usePointStyle: true,
                                padding: 15,
                                textDirection: isRtlMode ? 'rtl' : 'ltr'
                            }
                        }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
}