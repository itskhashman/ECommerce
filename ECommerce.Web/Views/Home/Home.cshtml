@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model ECommerce.Application.DTOs.Home.HomeDto

@{
    ViewData["Title"] = Localizer["HomeTitle"];
    var isRtl = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}

<style>
    body {
        background-image: linear-gradient(135deg, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.5)), url('/images/background.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        min-height: 100vh;
    }
</style>

<div class="container mt-4 pb-5">

    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 text-white rounded-3 overflow-hidden"
                 style="background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); min-height: 320px;">

                <div class="d-flex align-items-center h-100 p-4 p-md-5">
                    <div class="col-xl-8 col-lg-10 p-0 w-100">

                        <span class="badge bg-success bg-opacity-25 text-white border border-success-subtle fw-bold px-3 py-2 rounded-pill text-uppercase mb-3 tracking-wide d-inline-block"
                              style="font-size: 0.75rem; backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
                            @Localizer["NewArrivals"]
                        </span>

                        <h1 class="display-4 fw-bold text-white mb-2 tracking-tight">
                            @Localizer["HeroHeading"]
                        </h1>

                        <p class="fs-5 text-white-50 mb-4 fw-normal opacity-90 max-w-md">
                            @Localizer["HeroSubheading"]
                        </p>

                        <div class="mb-4 col-12 col-md-9 col-lg-7">
                            <form method="get" asp-controller="Search" asp-action="Search">
                                <div class="input-group input-group-lg border-0 shadow rounded-3 overflow-hidden"
                                     style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);">

                                    <span class="input-group-text bg-transparent border-0 text-muted @(isRtl ? "ps-0 pe-3" : "pe-0 ps-3")">
                                        <i class="bi bi-search"></i>
                                    </span>
                                    <input type="text"
                                           name="searchString"
                                           class="form-control bg-transparent border-0 px-3 py-3 fs-6 shadow-none text-dark"
                                           placeholder="@Localizer["SearchPlaceholder"]" />
                                    <button class="btn btn-success px-4 fw-bold text-white fs-6 m-1 rounded-2" type="submit">
                                        @Localizer["SearchButton"]
                                    </button>
                                </div>
                            </form>
                        </div>

                        <a href="#new-products" class="btn btn-success btn-lg px-4 py-2.5 fw-bold shadow-sm text-white rounded-pill d-inline-flex align-items-center gap-2">
                            @Localizer["ShopCollectionButton"]
                            <i class="bi @(isRtl ? "bi-arrow-left" : "bi-arrow-right") fs-5"></i>
                        </a>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bold text-dark m-0 position-relative pb-2">
                            @Localizer["ShopByCategory"]
                            <span class="position-absolute bottom-0 @(isRtl ? "end-0" : "start-0") bg-success rounded" style="width: 50px; height: 4px;"></span>
                        </h3>
                    </div>
                </div>

                <div class="d-flex flex-wrap justify-content-start align-items-top gap-4 py-2">
                    @if (Model.Categories != null)
                    {
                        foreach (var Category in Model.Categories)
                        {
                            var categoryImg = string.IsNullOrEmpty(Category.ImageUrl) ? $"/images/categories/{Category.Id}.jpg" : Category.ImageUrl;
                            var localizedCategoryName = isRtl ? Category.NameAr : Category.NameEn;

                            <a asp-controller="Search"
                               asp-action="Search"
                               asp-route-categoryId="@Category.Id"
                               class="d-flex flex-column align-items-center text-decoration-none"
                               style="width: 105px;">

                                <div class="rounded-circle d-flex align-items-center justify-content-center bg-body-secondary border border-light-subtle shadow-sm p-1"
                                     style="width: 90px; height: 90px; overflow: hidden; transition: transform 0.2s ease;"
                                     onmouseover="this.style.transform='scale(1.06)'"
                                     onmouseout="this.style.transform='scale(1)'">
                                    <img src="@categoryImg"
                                         onerror="this.onerror=null; this.src='/images/placeholder.jpg';"
                                         class="w-100 h-100 object-fit-cover rounded-circle"
                                         alt="@localizedCategoryName" />
                                </div>

                                <span class="mt-2 text-dark text-center text-wrap fw-semibold line-clamp-2"
                                      style="font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; min-height: 2.4rem; overflow: hidden;">
                                    @localizedCategoryName
                                </span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <div class="px-2">
                <h3 class="fw-bold text-white m-0 position-relative pb-2">
                    @Localizer["FeaturesServicesTitle"]
                    <span class="position-absolute bottom-0 @(isRtl ? "end-0" : "start-0") bg-success rounded" style="width: 50px; height: 4px;"></span>
                </h3>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm rounded-3 p-3 text-center bg-white">
                <div class="text-success mb-2">
                    <i class="bi bi-truck fs-2"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1 small">@Localizer["Feature1Title"]</h6>
                <p class="text-muted small m-0">@Localizer["Feature1Desc"]</p>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm rounded-3 p-3 text-center bg-white">
                <div class="text-success mb-2">
                    <i class="bi bi-credit-card-2-front fs-2"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1 small">@Localizer["Feature2Title"]</h6>
                <p class="text-muted small m-0">@Localizer["Feature2Desc"]</p>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm rounded-3 p-3 text-center bg-white">
                <div class="text-success mb-2">
                    <i class="bi bi-geo-alt fs-2"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1 small">@Localizer["Feature3Title"]</h6>
                <p class="text-muted small m-0">@Localizer["Feature3Desc"]</p>
            </div>
        </div>

        <div class="col-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm rounded-3 p-3 text-center bg-white">
                <div class="text-success mb-2">
                    <i class="bi bi-headset fs-2"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1 small">@Localizer["Feature4Title"]</h6>
                <p class="text-muted small m-0">@Localizer["Feature4Desc"]</p>
            </div>
        </div>
    </div>

    <div id="new-products" class="mt-5 pt-2">
        <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark m-0 position-relative pb-2">
                        @Localizer["NewProductsTitle"]
                        <span class="position-absolute bottom-0 @(isRtl ? "end-0" : "start-0") bg-success rounded" style="width: 50px; height: 4px;"></span>
                    </h3>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                @foreach (var product in Model.NewestProducts)
                {
                    var localizedProductName = isRtl ? product.NameAr : product.NameEn;
                    var localizedCategoryName = isRtl ? product.CategoryNameAr : product.CategoryNameEn;

                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden position-relative bg-light">

                            <div class="bg-body-secondary d-flex align-items-center justify-content-center p-3 position-relative" style="height: 220px; overflow: hidden;">
                                @{
                                    var mainImg = product.ProductImages?.FirstOrDefault(img => img.IsMain && !img.IsDeleted)?.URL;
                                    var hasDiscount = product.DiscountTypeId.HasValue && product.DiscountAmount > 0;
                                }

                                <img src="@(string.IsNullOrEmpty(mainImg) ? "/images/placeholder.jpg" : mainImg)"
                                     class="img-fluid rounded"
                                     style="max-height: 100%; object-fit: contain;"
                                     alt="@localizedProductName" />

                                @if (hasDiscount)
                                {
                                    <span class="badge bg-success position-absolute top-0 start-0 m-3 px-2.5 py-1.5 fw-bold shadow-sm" style="z-index: 10; font-size: 0.75rem;">
                                        @if (product.DiscountTypeId == 1)
                                        {
                                            <span>-@((product.DiscountAmount.Value).ToString("G0"))%</span>
                                        }
                                        else
                                        {
                                            <span>@Localizer["SavePrefix"] @product.DiscountAmount.Value.ToString("N2") @Localizer["Currency"]</span>
                                        }
                                    </span>
                                }
                            </div>

                            <div class="card-body d-flex flex-column p-3 bg-white">
                                <span class="text-muted text-uppercase fw-semibold tracking-wider mb-1" style="font-size: 0.7rem;">
                                    @localizedCategoryName
                                </span>

                                <h6 class="card-title text-dark fw-bold text-truncate mb-2">
                                    <a asp-controller="Search" asp-action="Details" asp-route-productId="@product.Id" class="text-decoration-none text-dark stretched-link">
                                        @localizedProductName
                                    </a>
                                </h6>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>