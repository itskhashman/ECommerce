@model ECommerce.Application.DTOs.Home.HomeDto
@{
    ViewData["Title"] = "Home";
}
<div class="container mt-4">
    <div class="row g-4">

        <div class="col-lg-3 col-md-4">
            <div class="card rounded-3">
                <div class="bg-dark text-white p-3 d-flex align-items-center">
                    <div class="d-flex align-items-center">
                        <h5 class="m-0 fw-bold smallmy-1">Categories</h5>
                    </div>
                </div>

                <ul class="list-group">
                    @for (int i = 0; i < Model.Categories.Count(); i++)
                    {
                        var mainCategory = Model.Categories.ElementAt(i);
                        var targetId = $"categoryCollapse_{i}";
                        var hasChildren = mainCategory.Children != null && mainCategory.Children.Any();

                        <li class="list-group-item p-0 border-bottom border-light-subtle">
                                <a class="d-flex align-items-center py-3 px-3 fw-semibold text-dark small text-decoration-none">
                                    <i class="bi bi-folder2 text-dark mx-1"></i> @mainCategory.NameEn
                                </a>
                        </li>

                    }
                </ul>
            </div>
        </div>
        <div class="col-lg-9 col-md-8">

            <div class="mb-4">
                <form method="get" asp-controller="Search" asp-action="Search">
                    <div class="input-group input-group-lg border border-light-subtle rounded-3 overflow-hidden bg-white">
                        <span class="input-group-text bg-white border-0 text-muted pe-0">
                            <i class="bi bi-search ms-1"></i>
                        </span>
                        <input type="text"
                               name="searchString"
                               class="form-control border-0 px-3 py-3 fs-6 shadow-none"
                               placeholder="Search brand new styles, gadgets, clothing items..." />
                        <button class="btn btn-dark text-success px-5 fw-bold" type="submit">Search</button>
                    </div>
                </form>
            </div>

        </div>
    </div>

    <div id="featured-products" class="mt-5 pt-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark m-0">Featured Products</h3>
            </div>
        
        </div>
    </div>
</div>