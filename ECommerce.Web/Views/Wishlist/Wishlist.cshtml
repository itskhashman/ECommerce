@model ECommerce.Application.DTOs.Wishlist.WishlistDto
@{
    ViewData["Title"] = "My Wishlist";
}
<div class="container my-5">


    @if (Model == null || Model.WishlistItems == null || !Model.WishlistItems.Any())
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center py-5 bg-white">
                <h3 class="fw-bold text-dark mb-2">Your Wishlist is Empty</h3>
                <p class="text-secondary small mb-4 px-4">
                    Looks like you haven't added anything to your wishlist yet. Explore our latest arrivals and find something special!
                </p>
                <a asp-controller="Home" asp-action="Home" class="btn btn-dark rounded-0 px-5 py-2 fw-bold text-uppercase">
                    Start Shopping
                </a>
            </div>
        </div>
    }
    else
    {

        <div class="row mb-4">
            <div class="col-12">
                <h2 class="fw-bold text-dark">My Wishlist</h2>
                <p class="text-muted small">Manage items you saved and want to purchase later.</p>
                <hr />
            </div>
        </div>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model.WishlistItems)
            {
                <div class="col">
                    <a asp-controller="Search" asp-action="Details" asp-route-productId="@item.ProductId" class="text-decoration-none h-100 d-block">
                        <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden position-relative product-wishlist-card">

                            <button class="btn btn-light btn-sm text-danger rounded-circle shadow-sm position-absolute border-0"
                                    style="top: 12px; right: 12px; z-index: 10; width: 32px; height: 32px; display: grid; place-content: center;"
                                    onclick="event.preventDefault(); removeItem(@item.ProductId);">
                                <i class="bi bi-trash fs-6"></i>
                            </button>

                            <div class="bg-white d-flex align-items-center justify-content-center p-3 wishlist-img-wrapper" style="height: 200px; overflow: hidden;">
                                @{
                                    var mainImg = item.Product.ProductImages?.FirstOrDefault(img => img.IsMain && !img.IsDeleted)?.URL;
                                }
                                <img src="@(string.IsNullOrEmpty(mainImg) ? "/images/placeholder.jpg" : mainImg)"
                                     class="img-fluid rounded wishlist-card-img"
                                     style="max-height: 100%; object-fit: contain;"
                                     alt="@item.Product.NameEn" />
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <h6 class="card-title text-dark fw-semibold text-truncate mb-1" title="@item.Product.NameEn">
                                    @item.Product.NameEn
                                </h6>

                                <div class="mb-3">
                                    @{
                                        var productPrice = item.Product.Skus?.FirstOrDefault()?.Price;
                                    }
                                    <span class="fs-5 fw-bold text-success">
                                        @(productPrice.HasValue? productPrice.Value.ToString("N2") : "0.00")
                                    </span>
                                    <span class="fs-7 fw-medium text-success ms-1">JOD</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
<style>
    .product-wishlist-card .wishlist-card-img {
        transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out;
        opacity: 1;
    }

    .product-wishlist-card:hover .wishlist-card-img {
        opacity: 0.65;
        transform: scale(1.03); 
    }


</style>
@section scripts {
    <script>

        async function removeItem(productId){
            if (!confirm("Are you sure you want to remove this item from your wishlist?")) return;

            var userId = @Model?.UserId ?? 0;
            try {
                const response = await fetch(`/api/Wishlist/RemoveFromWishlist?productId=${productId}&userId=${userId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Failed to remove item from wishlist. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while removing the item. Please try again.');
            }
        }
    </script>
}