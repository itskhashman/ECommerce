@using System.Globalization
@model ECommerce.Application.DTOs.User.UpdateUserDto

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["EditInformationTitle"];
}

<div class="container my-5" style="max-width: 750px;" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="card border rounded-0 shadow-sm bg-white">
        <div class="card-header bg-dark text-white py-3 rounded-0">
            <h5 class="m-0 text-uppercase small fw-bold">
                <i class="bi bi-person-gear me-2"></i>@Localizer["EditPersonalInformation"]
            </h5>
        </div>
        <form asp-controller="Profile" asp-action="Edit" method="post" class="p-4">
            <input type="hidden" asp-for="Id" />

            <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-2 mb-3 @(isArabic ? "text-start" : "")" dir="ltr">
                @Localizer["ProfileDetailsEnglishHeader"]
            </h6>
            <div class="row g-3 mb-4" dir="ltr">
                <div class="col-md-4">
                    <label class="form-label text-uppercase text-muted fw-bold small mb-1">@Localizer["FirstNameEnLabel"]</label>
                    <input type="text" asp-for="FirstNameEn" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="FirstNameEn" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-uppercase text-muted fw-bold small mb-1">@Localizer["MiddleNameEnLabel"]</label>
                    <input type="text" asp-for="MiddleNameEn" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="MiddleNameEn" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-uppercase text-muted fw-bold small mb-1">@Localizer["LastNameEnLabel"]</label>
                    <input type="text" asp-for="LastNameEn" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="LastNameEn" class="text-danger small"></span>
                </div>
            </div>

            <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-2 mb-3 @(isArabic ? "text-end" : "")" dir="rtl">
                @Localizer["ProfileDetailsArabicHeader"]
            </h6>
            <div class="row g-3 mb-4" dir="rtl">
                <div class="col-md-4 @(isArabic ? "text-start" : "text-end")">
                    <label class="form-label text-muted fw-bold small mb-1">@Localizer["FirstNameArLabel"]</label>
                    <input type="text" asp-for="FirstNameAr" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="FirstNameAr" class="text-danger small"></span>
                </div>
                <div class="col-md-4 @(isArabic ? "text-start" : "text-end")">
                    <label class="form-label text-muted fw-bold small mb-1">@Localizer["MiddleNameArLabel"]</label>
                    <input type="text" asp-for="MiddleNameAr" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="MiddleNameAr" class="text-danger small"></span>
                </div>
                <div class="col-md-4 @(isArabic ? "text-start" : "text-end")">
                    <label class="form-label text-muted fw-bold small mb-1">@Localizer["LastNameArLabel"]</label>
                    <input type="text" asp-for="LastNameAr" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="LastNameAr" class="text-danger small"></span>
                </div>
            </div>

            <h6 class="fw-bold text-secondary text-uppercase small border-bottom pb-2 mb-3">
                @Localizer["ContactConfigurationHeader"]
            </h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label text-uppercase text-muted fw-bold small mb-1">@Localizer["PhoneNumberLabel"]</label>
                    <input type="tel" asp-for="Phone" class="form-control rounded-0 font-monospace small" required />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
            </div>

            <div class="pt-3 border-top d-flex justify-content-end gap-2">
                <a asp-controller="Profile" asp-action="MyProfile" class="btn btn-outline-secondary rounded-0 text-uppercase small px-4">
                    @Localizer["CancelButton"]
                </a>
                <button type="submit" class="btn btn-dark rounded-0 text-uppercase small px-4">
                    @Localizer["SaveProfileButton"]
                </button>
            </div>
        </form>
    </div>
</div>