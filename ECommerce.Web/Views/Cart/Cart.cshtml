@using System.Globalization
@model ECommerce.Application.DTOs.Cart.CartDto

@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    var isArabic = CultureInfo.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = Localizer["ShoppingCartTitle"];

    var subtotal = Model?.CartItems?.Sum(item => item.Sku.Price * item.Quantity) ?? 0;
    var totalDiscount = Model?.CartItems?.Sum(item => ((item.Sku.Price - item.PriceAtAddTime) * item.Quantity)) ?? 0;
    var finalTotal = subtotal - totalDiscount;
}

<div class="container my-5" dir="@(isArabic ? "rtl" : "ltr")">

    @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center py-5 bg-white">
                <h3 class="fw-bold text-dark mb-2">@Localizer["CartEmptyHeader"]</h3>
                <p class="text-secondary small mb-4 px-4">
                    @Localizer["CartEmptyDescription"]
                </p>
                <a asp-controller="Home" asp-action="Home" class="btn btn-dark rounded-0 px-5 py-2 fw-bold text-uppercase">
                    @Localizer["StartShopping"]
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row mb-4">
            @await Html.PartialAsync("_CheckoutSteps", "Cart")
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border rounded-0 shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <label class="form-check-label fw-bold text-uppercase text-dark fs-5">
                                @Localizer["AllItems"] (@Model.CartItems.Count.ToString(CultureInfo.InvariantCulture))
                            </label>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        @foreach (var item in Model.CartItems)
                        {
                            if (item?.Sku?.Product == null) continue;

                            var productName = isArabic ? item.Sku.Product.NameAr : item.Sku.Product.NameEn;
                            var productDesc = isArabic ? item.Sku.Product.DescriptionAr : item.Sku.Product.DescriptionEn;

                            <div class="p-3 border-bottom">
                                <div class="row g-3 align-items-start">

                                    <div class="col-3 col-sm-2 d-flex align-items-center justify-content-between">
                                        <div class="border bg-light overflow-hidden w-100" style="aspect-ratio: 3/4;">
                                            @if (item.Sku.Product.ProductImages != null && item.Sku.Product.ProductImages.Any())
                                            {
                                                var mainImage = item.Sku.Product.ProductImages.FirstOrDefault(img => img.IsMain)
                                                ?? item.Sku.Product.ProductImages.First();
                                                <img src="@mainImage.URL" class="w-100 h-100 img-fluid" style="object-fit: cover;" alt="@productName">
                                            }
                                            else
                                            {
                                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted small bg-secondary-subtle">@Localizer["NoImg"]</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="col-9 col-sm-10">
                                        <p class="small text-secondary mb-1 lh-sm text-wrap">
                                            <strong class="text-dark">@productName</strong> <br> @productDesc
                                        </p>

                                        <div class="my-2">
                                            <span class="badge bg-light text-dark border rounded-pill px-2 py-1 small fw-normal">
                                                @item.Sku.SkuCode
                                            </span>
                                        </div>

                                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mt-3">
                                            <div>
                                                <span class="fw-bolder text-danger fs-5 font-monospace" dir="ltr">
                                                    @Localizer["JOD"] @item.PriceAtAddTime.ToString("F2", CultureInfo.InvariantCulture)
                                                </span>
                                                @if (item.Sku.Price > item.PriceAtAddTime)
                                                {
                                                    <span class="text-decoration-line-through text-muted small ms-2 font-monospace">
                                                        @Localizer["JOD"] @item.Sku.Price.ToString("F2", CultureInfo.InvariantCulture)
                                                    </span>
                                                }
                                            </div>

                                            <div class="d-flex align-items-center gap-3">
                                                <div class="input-group input-group-sm" style="max-width: 90px;">
                                                    <button class="btn btn-outline-secondary px-2"
                                                            type="button"
                                                            onclick="changeQuantity(@Model.UserId, @item.SkuId, -1)">
                                                        -
                                                    </button>

                                                    <input type="text"
                                                           class="form-control bg-white text-center font-monospace px-1"
                                                           id="qty-@item.SkuId"
                                                           value="@item.Quantity.ToString(CultureInfo.InvariantCulture)"
                                                           readonly
                                                           data-max-stock="@item.Sku.Stock.ToString(CultureInfo.InvariantCulture)">

                                                    <button class="btn btn-outline-secondary px-2"
                                                            type="button"
                                                            onclick="changeQuantity(@Model.UserId, @item.SkuId, 1)">
                                                        +
                                                    </button>
                                                </div>

                                                <div class="d-flex gap-2">
                                                    <button type="button"
                                                            class="btn btn-link text-danger p-0 border-0"
                                                            onclick="removeItemFromCart(@Model.UserId, @item.SkuId)">
                                                        <i class="bi bi-trash3"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border rounded-0 shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold text-dark mb-3">@Localizer["OrderSummary"]</h5>

                        <div class="d-flex justify-content-between mb-2 small text-dark fw-bold">
                            <span>@Localizer["TotalPrice"]:</span>
                            <span class="font-monospace">@Localizer["JOD"] @subtotal.ToString("F2", CultureInfo.InvariantCulture)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 small text-success fw-bold">
                            <span>@Localizer["Promotions"]:</span>
                            <span class="font-monospace">-@Localizer["JOD"] @totalDiscount.ToString("F2", CultureInfo.InvariantCulture)</span>
                        </div>

                        <hr class="my-3">

                        <div class="d-flex justify-content-between align-items-baseline mb-4">
                            <span class="fw-bold text-dark m-0 fs-5">@Localizer["EstimatedPrice"]:</span>
                            <div class="text-end">
                                <span class="fw-bolder text-danger fs-3 font-monospace m-0 d-block">
                                    @Localizer["JOD"] @finalTotal.ToString("F2", CultureInfo.InvariantCulture)
                                </span>
                            </div>
                        </div>

                        @{
                            var checkoutItemCount = Model.CartItems.Sum(i => i.Quantity).ToString(CultureInfo.InvariantCulture);
                        }
                        <a asp-controller="Orders" asp-action="PlaceOrder" class="btn btn-dark w-100 rounded-0 py-3 fw-bold text-uppercase mb-2">
                            @Localizer["CheckoutNow"] (@checkoutItemCount)
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        async function changeQuantity(userId, skuId, direction) {
            const input = document.getElementById(`qty-${skuId}`);
            const maxStock = parseInt(input.getAttribute('data-max-stock')) || 10;
            let currentQty = parseInt(input.value) || 1;

            let targetQty = currentQty + direction;

            if (targetQty < 1) {
                if(confirm("Remove this item from your shopping cart?")) {
                    await removeItemFromCart(userId, skuId);
                }
                return;
            }

            if (targetQty > maxStock) {
                alert(`Sorry, you can only purchase a maximum of ${maxStock} items.`);
                return;
            }

            try {
                const response = await fetch(`/api/Cart/UpdateQuantity/${userId}/${skuId}?quantity=${targetQty}`, {
                    method: 'POST',
                    headers: { 'Accept': 'application/json' }
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    input.value = targetQty;
                    location.reload();
                } else {
                    alert(data.message || "Failed to adjust cart quantities.");
                }
            } catch (error) {
                console.error("Error modifying quantity:", error);
            }
        }

        async function removeItemFromCart(userId, skuId) {
            try {
                const response = await fetch(`/api/Cart/RemoveItem/${userId}/${skuId}`, {
                    method: 'DELETE',
                    headers: { 'Accept': 'application/json' }
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    location.reload();
                } else {
                    alert(data.message || "Could not completely remove item.");
                }
            } catch (error) {
                console.error("Error removing item:", error);
            }
        }
    </script>
}