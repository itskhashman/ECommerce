@model ECommerce.Application.DTOs.Products.CreateProductDto

@{
    Layout = "_Layout";
}

<body>
    <div class="container mt-4">
        <h1>Create Product</h1>

        <form asp-action="Create" method="post">
            <div class="form-group mb-3">
                <label asp-for="NameEn" class="form-label">Name (English)</label><span class="text-danger">*</span>
                <input asp-for="NameEn" class="form-control" />
                <span asp-validation-for="NameEn" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NameAr" class="form-label">Name (Arabic)</label><span class="text-danger">*</span>
                <input asp-for="NameAr" class="form-control" />
                <span asp-validation-for="NameAr" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DescriptionEn" class="form-label">Description (English)</label><span class="text-danger">*</span>
                <textarea asp-for="DescriptionEn" class="form-control" rows="3"></textarea>
                <span asp-validation-for="DescriptionEn" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="DescriptionAr" class="form-label">Description (Arabic)</label><span class="text-danger">*</span>
                <textarea asp-for="DescriptionAr" class="form-control" rows="3"></textarea>
                <span asp-validation-for="DescriptionAr" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ImageFiles" class="form-label">Images (Optional)</label>
                <input asp-for="ImageFiles" type="file" class="form-control" accept="image/*" multiple />
            </div>

            <div class="form-group mb-3">
                <label asp-for="MainCategoryId" class="form-label">Main Category</label><span class="text-danger">*</span>
                <select asp-for="MainCategoryId" class="form-select" asp-items="ViewBag.MainCategories">
                    <option value="">-- Select Main Category --</option>
                </select>
                <span asp-validation-for="MainCategoryId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="form-label">Sub Category</label><span class="text-danger">*</span>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.SubCategories">
                    <option value="">-- Select Sub Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="card shadow-sm border border-light rounded-3 mb-4">
                <div class="card-header bg-secondary text-white py-3">
                    <h5 class="mb-0 fw-bold">Product Variants & Options</h5>
                </div>

                <div class="card-body p-4 bg-light" id="variantsList">
                </div>

                <div class="card-footer bg-light p-3 text-center border-top-0">
                    <button type="button" class="btn btn-outline-primary fw-medium px-4" onclick="addProductVariant()">
                        <i class="bi bi-plus-circle me-2"></i>Add New Variant
                    </button>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>
</body>

@section Scripts {
    <script>
        let variantIndex = 0;

        function getVariantCardTemplate(index) {
            return `
                <div class="card shadow-sm mb-4 border-secondary variant-item-card" id="variant_card_${index}">
                    <div class="card-body p-3">
                        <div class="row align-items-center mb-3">
                            <div class="col-md-8">
                                <label class="form-label fw-bold text-secondary">Variant Name</label>
                                <input type="text" name="ProductVariants[${index}].VariantName" class="form-control" placeholder="e.g., Size, Color, Material" required />
                            </div>
                            <div class="col-md-4 col-12 text-end mt-4">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeProductVariant(${index})">
                                    <i class="bi bi-trash me-1"></i>Remove Variant
                                </button>
                            </div>
                        </div>

                        <div class="bg-white p-3 rounded border">
                            <label class="form-label small fw-bold text-muted d-block mb-2">Variant Options (1 at least)</label>

                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <div class="d-flex flex-wrap gap-2 badge-container" id="badge_container_${index}" data-option-count="0"></div>

                                <div class="input-group input-group-sm" style="max-width: 250px;">
                                    <input type="text" class="form-control value-input" id="input_field_${index}" placeholder="Add value (e.g., Red)" />
                                    <button class="btn btn-secondary" type="button" onclick="addProductVariantOption(${index})">Add</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>`;
        }

        function addProductVariant() {
            let container = document.getElementById("variantsList");

            let variantCardHtml = getVariantCardTemplate(variantIndex);

            container.insertAdjacentHTML('beforeend',variantCardHtml)
            
            variantIndex++;
        }

        function addProductVariantOption(cardId) {
            let inputField = document.getElementById(`input_field_${cardId}`);
            let badgeContainer = document.getElementById(`badge_container_${cardId}`);

            let optionValue = inputField.value.trim();
            if (!optionValue) return;

            let optionIndex = parseInt(badgeContainer.getAttribute("data-option-count"));

            let productVariantOption = `
                <div class="badge bg-primary d-flex align-items-center p-2 fs-6 fw-normal text-white">
                    <span>${optionValue}</span>
                    <input type="hidden" name="ProductVariants[${cardId}].VariantOptionsRaw[${optionIndex}]" value="${optionValue}" />
                    <button type="button" class="btn-close btn-close-white ms-2 small" onclick="this.parentElement.remove()" style="font-size: 0.65rem;"></button>
                </div>`;

            badgeContainer.insertAdjacentHTML('beforeend', productVariantOption);

            badgeContainer.setAttribute("data-option-count", optionIndex + 1);

            inputField.value = "";
        }

        function removeProductVariant(cardId) {
            let element = document.getElementById(`variant_card_${cardId}`);
            let sure = confirm("Are you sure you want to delete this variant ?");
            if (element && sure) {
                element.remove();
            }
        }
    </script>
}