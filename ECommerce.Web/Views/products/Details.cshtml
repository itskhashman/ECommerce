@model ECommerce.Application.DTOs.Products.ProductDto

@{
    Layout = "_Layout";
    var mainImage = Model.ProductImages?.FirstOrDefault(img => img.IsMain) ?? Model.ProductImages?.FirstOrDefault();
    var secondaryImages = Model.ProductImages?.Where(img => img != mainImage).ToList() ?? new List<ECommerce.Application.DTOs.ProductImage.ProductImageDto>();
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold m-0">Product Details</h2>
            <p class="text-muted small m-0">Review product specifications, images, and variants</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-light px-4 border fw-medium shadow-sm">
                <i class="bi bi-arrow-left me-2"></i>Back to List
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 shadow-sm fw-medium">
                <i class="bi bi-pencil-fill me-2"></i>Edit Product
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 bg-white rounded-3 p-3 text-center h-100">
                <label class="form-label small fw-bold text-secondary uppercase text-start d-block mb-3">Product Images</label>

                <div class="main-image-container border rounded bg-light mb-3 d-flex align-items-center justify-content-center overflow-hidden" style="height: 350px;">
                    @if (mainImage != null && !string.IsNullOrEmpty(mainImage.URL))
                    {
                        <img src="@mainImage.URL" id="mainDisplayImage" class="w-100 h-100" style="object-fit: contain;" alt="@Model.NameEn" />
                    }
                    else
                    {
                        <div class="text-muted text-center">
                            <i class="bi bi-image text-black-50" style="font-size: 3rem;"></i>
                            <span class="d-block mt-2 small">No image uploaded</span>
                        </div>
                    }
                </div>

                @if (Model.ProductImages != null && Model.ProductImages.Count > 1)
                {
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        @foreach (var img in Model.ProductImages)
                        {
                            <img src="@img.URL"
                                 class="rounded border shadow-sm img-thumbnail-selector"
                                 style="width: 65px; height: 50px; object-fit: cover; cursor: pointer; transition: 0.2s;"
                                 onclick="switchMainImage(this.src)"
                                 alt="Thumbnail" />
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 bg-white rounded-3 p-4 h-100">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                    <div>
                        <h3 class="fw-bold text-dark m-0">@Model.NameEn</h3>
                    </div>
                    <div>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-medium">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-pill fw-medium">Inactive</span>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-secondary uppercase">Description</label>
                    <div class="bg-light p-3 rounded border text-secondary mb-3" style="white-space: pre-line;">
                        @Model.DescriptionEn
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="border rounded p-3 bg-light h-100">
                            <span class="text-muted d-block small mb-1">
                                <i class="bi bi-tags-fill me-1 text-secondary"></i>Category
                            </span>
                            <span class="fw-bold text-dark">
                                @Model.CategoryNameEn
                            </span>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="border rounded p-3 bg-light h-100">
                            <span class="text-muted d-block small mb-2">
                                <i class="bi bi-info-circle-fill me-1 text-secondary"></i>System Records
                            </span>
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Created On:</small>
                                    <small class="fw-medium text-dark">
                                        @(Model.CreatedAt != default ? Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt") : "N/A")
                                    </small>
                                </div>
                                @if (Model.ModifiedAt.HasValue)
                                {
                                    <div class="d-flex justify-content-between align-items-center border-top pt-1 mt-1">
                                        <small class="text-muted">Last Modified:</small>
                                        <small class="fw-medium text-dark">
                                            @Model.ModifiedAt.Value.ToString("MMM dd, yyyy hh:mm tt")
                                        </small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="border rounded p-3 bg-light h-100 d-flex flex-column justify-content-center gap-2">

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">Discount Type</span>
                                <span class="fw-bold text-dark">
                                    @(string.IsNullOrEmpty(Model.DiscountTypeName) ? "None" : Model.DiscountTypeName)
                                </span>
                            </div>

                            <hr class="m-0 text-black-50 opacity-25" />

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small">Amount</span>
                                <span class="fw-bold text-dark">
                                    @if (Model.DiscountTypeId == 1 && Model.DiscountAmount.HasValue)
                                    {
                                        <span>@Model.DiscountAmount%</span>
                                    }
                                    else if (Model.DiscountAmount.HasValue)
                                    {
                                        <span>@Model.DiscountAmount JOD</span>
                                    }
                                    else
                                    {
                                        <span>--</span>
                                    }
                                </span>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 bg-white rounded-3 mt-4 overflow-hidden">
        <div class="card-header bg-secondary text-white py-3">
            <h5 class="mb-0 fw-bold">Assigned Product Variants &amp; Options</h5>
        </div>
        <div class="card-body p-4 bg-light">
            @if (Model.ProductVariants != null && Model.ProductVariants.Any())
            {
                <div class="row g-3">
                    @foreach (var variant in Model.ProductVariants)
                    {
                        <div class="col-12">
                            <div class="card shadow-sm border border-light rounded-3 bg-white mb-2">
                                <div class="card-body p-3">
                                    <div class="row align-items-center">
                                        <div class="col-md-4 mb-2 mb-md-0">
                                            <small class="text-muted d-block">Variant Name</small>
                                            <span class="fw-bold text-dark">@variant.NameEn</span>
                                        </div>
                                        <div class="col-md-8">
                                            <div class="p-2 border rounded bg-light d-flex flex-wrap gap-2">
                                                @if (variant.ProductVariantOptions != null && variant.ProductVariantOptions.Any())
                                                {
                                                    @foreach (var option in variant.ProductVariantOptions.OrderBy(o => o.SortOrder))
                                                    {
                                                        <div class="badge bg-primary p-2 fs-6 fw-normal text-white shadow-sm">
                                                            <span>@option.NameEn</span>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small p-1">No options configured for this variant type.</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-4 bg-white border rounded text-muted">
                    <i class="bi bi-sliders text-black-50 fs-3 d-block mb-2"></i>
                    <span>No variants exist for this product.</span>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchMainImage(src) {
            const mainDisplay = document.getElementById('mainDisplayImage');
            if (mainDisplay) {
                mainDisplay.src = src;
            }
        }
    </script>
}