@model ECommerce.Application.DTOs.Products.ProductDto

@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ProductImages.FirstOrDefault(img => img.IsMain)?.URL" alt="@Model.ProductImages.FirstOrDefault(img => img.IsMain)?.AltText" class="img-fluid" />
        </div>
        <div class="col-md-6">
            <h2>@Model.NameAr</h2>
            <p>@Model.NameEn</p>
            <h4>$@Model.DescriptionAr</h4>
            <h4>$@Model.DescriptionEn</h4>
            <button class="btn btn-primary">Add to Cart</button>
        </div>
    </div>
</div>
