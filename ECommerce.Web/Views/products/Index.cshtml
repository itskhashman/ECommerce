@model IEnumerable<ECommerce.Application.DTOs.Products.ProductDto>
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold m-0">Manage Products</h2>
            <p class="text-muted small m-0">Manage your application products</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 shadow-sm fw-medium">
            Add Product
        </a>
    </div>

    <div class="card shadow-sm border-0 bg-white rounded-3 overflow-hidden p-3">
        <div class="table-responsive">
            <table id="productsTable" class="table table-hover align-middle m-0 w-100">
                <thead class="table-light border-bottom">
                    <tr>
                        <th class="py-3 px-4 text-secondary uppercase fs-7 fw-bold">Product Name</th>
                        <th class="py-3 text-secondary uppercase fs-7 fw-bold">Main Image</th>
                        <th class="py-3 text-secondary uppercase fs-7 fw-bold">Active Status</th>
                        <th class="py-3 px-4 text-secondary uppercase fs-7 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="d-block mb-2 fs-5">No products found</span>
                            </td>
                        </tr>
                    }

                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="py-3 px-4 fw-bold text-dark">
                                @product.NameEn
                            </td>

                            <td class="py-3">
                                @{
                                    var mainImage = product.ProductImages?.FirstOrDefault(img => img.IsMain)
                                    ?? product.ProductImages?.FirstOrDefault();

                                    if (mainImage != null && !string.IsNullOrEmpty(mainImage.URL))
                                    {
                                        <img src="@mainImage.URL"
                                             width="60"
                                             height="45"
                                             class="rounded border shadow-sm"
                                             style="object-fit:cover;"
                                             alt="@product.NameEn" />
                                    }
                                    else
                                    {
                                        <div class="bg-light text-muted rounded border shadow-sm d-flex align-items-center justify-content-center"
                                             style="width:60px; height:45px; font-size: 0.75rem;">
                                            <i class="bi bi-image text-black-50"></i>
                                        </div>
                                    }
                                }
                            </td>

                            <td class="py-3">
                                @if (product.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 rounded-pill fw-medium">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2.5 py-1.5 rounded-pill fw-medium">Inactive</span>
                                }
                            </td>

                            <td class="py-3 px-4 text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-light btn-sm px-3 border fw-medium shadow-sm" title="Details">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-light btn-sm px-3 border fw-medium shadow-sm" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    <form asp-action="Delete" asp-route-id="@product.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this product?');" class="m-0">
                                        <button type="submit" class="btn btn-outline-danger btn-sm px-3 fw-medium shadow-sm" title="Delete">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#productsTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": false,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "dom": "<'row mb-3'<'col-sm-6'l><'col-sm-6 text-end'f>>" +
                       "<'row'<'col-sm-12'tr>>" +
                       "<'row mt-3'<'col-sm-5'i><'col-sm-7 text-end'p>>",
                "columnDefs": [
                    { "orderable": false, "targets": [1, 3] }
                ]
            });
        });
    </script>
}