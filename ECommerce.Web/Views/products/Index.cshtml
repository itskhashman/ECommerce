@model IEnumerable<ECommerce.Application.DTOs.Products.ProductDto>
@{
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold">Manage Products</h2>
            <p class="text-muted small">Manage your application products</p>
        </div>
        <a asp-action="Create" class="btn btn-success px-4 shadow-sm fw-medium">
            Add Product
        </a>
    </div>

    <div class="card shadow-sm p-3">
        <div class="table-responsive">
            <table id="productsTable" class="table table-striped table-hover align-middle mb-0 w-100">
                <thead class="bg-light border-bottom">
                    <tr>
                        <th class="py-3 px-4 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Product Name</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Main Image</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-bold" style="letter-spacing: 0.5px; font-size: 0.75rem;">Active Status</th>
                        <th class="py-3 px-4 text-secondary text-uppercase fs-7 fw-bold text-end" style="letter-spacing: 0.5px; font-size: 0.75rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark">
                                    @product.NameEn
                                </td>
                                <td>
                                    @{
                                        var mainImage = product.ProductImages?.FirstOrDefault(img => img.IsMain)
                                        ?? product.ProductImages?.FirstOrDefault();

                                        if (mainImage != null && !string.IsNullOrEmpty(mainImage.URL))
                                        {
                                            <img src="@mainImage.URL"
                                                 width="60"
                                                 height="45"
                                                 class="rounded border shadow-sm"
                                                 style="object-fit:cover;"
                                                 alt="@product.NameEn" />
                                        }
                                        else
                                        {
                                            <div class="bg-light text-muted rounded border shadow-sm d-flex align-items-center justify-content-center"
                                                 style="width:60px; height:45px; font-size: 0.75rem;">
                                                <i class="bi bi-image text-black-50"></i>
                                            </div>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group gap-2 justify-content-end">
                                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-success shadow-sm" title="Details">
                                            View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-success shadow-sm" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@product.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this product?');" class="m-0">
                                            <button type="submit" class="btn btn-sm btn-danger shadow-sm" title="Delete">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#productsTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "columnDefs": [
                    { "orderable": false, "targets": [1, 3] }
                ]
            });
        });
    </script>
}